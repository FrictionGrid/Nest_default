1 npm i -g @nestjs/cli = ติดตั้ง Nest CLI
2 nest new "name project" = สร้างโปรเจคใหม่
3 npm run start:dev = คำสั่งรัน server
4 npm install @nestjs/config 
5 สร้างไฟล์ .env เเละ .env.example นอกสุด
6 ไฟล์ public สร้างได้เลย
7 สร้าง docker-compose.yml นอกสุด
8 npm install ejs = ติดตั้ง EJS
9 ศึกษาฟังชั่นของ node_modules
10 จัดการไฟล์ main.ts กับ AppModule
11 nest g resource "name" = คำสั่งสร้างไฟล์
12 จัดการ DB ไว้ในที่เดียวกัน
13 npm install @nestjs/typeorm typeorm pg = ตัวเชื่อม DB
14 npm run typeorm migration:create src/database/migrations/'name' = คำสั่งรันสร้างDB
15 package.json setting
16 Project - Docker - Dbeaver
17 npm run typeorm migration:run -- -d src/database/database.ts = รัน migrate
18 ต้องมาเล่น migrate หน่อย 
19 npm install ejs express-ejs-layouts = สำหรับทำ layouts
20  docker compose up -d   ใช้เปิด docker
21 npm install class-validator class-transformer = สำหรับ eto
22 npm install express-session @types/express-session 2>&1 = ใช้ทำ session