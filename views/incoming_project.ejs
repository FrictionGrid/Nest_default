<link rel="stylesheet" href="/css/tools/table.css" />
<style>
  .project-name-link {
    color: var(--primary);
    text-decoration: none;
    transition: color 0.2s;
  }
  .project-name-link:hover { color: var(--accent); }

  .type-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .type-badge {
    background: var(--info);
    color: var(--info-text);
    border-radius: 6px;
    padding: 3px 8px;
    font-size: 8px;
    font-weight: 600;
    white-space: nowrap;
  }

  .type-checkbox-group {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px 12px;
    border: 1px solid #cdd9e8;
    border-radius: 10px;
    padding: 12px 14px;
    background: #fff;
  }
  .type-checkbox-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    color: var(--text);
    cursor: pointer;
  }
  #fieldRegion {
    height: 40px;
    border: 1px solid #cdd9e8;
    border-radius: 10px;
    padding: 0 14px;
    font-size: 15px;
    color: var(--text);
    outline: none;
    transition: border 0.2s;
    background: #fff;
    width: 100%;
  }
  #fieldRegion:focus { border-color: #4179bf; }

  .type-checkbox-item input[type="checkbox"] {
    width: 15px;
    height: 15px;
    cursor: pointer;
    accent-color: #4179bf;
    flex-shrink: 0;
  }
</style>

<section class="content">
  <div class="toolbar">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none">
        <path
          d="M21 21L16.65 16.65M10.5 18C14.6421 18 18 14.6421 18 10.5C18 6.35786 14.6421 3 10.5 3C6.35786 3 3 6.35786 3 10.5C3 14.6421 6.35786 18 10.5 18Z"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <input type="text" id="searchInput" placeholder="Search Item, Project Name, Sales Name..." />
    </div>

    <select id="filterStatus" class="filter-box">
      <option value="">All Months</option>
      <option value="1">January</option>
      <option value="2">February</option>
      <option value="3">March</option>
      <option value="4">April</option>
      <option value="5">May</option>
      <option value="6">June</option>
      <option value="7">July</option>
      <option value="8">August</option>
      <option value="9">September</option>
      <option value="10">October</option>
      <option value="11">November</option>
      <option value="12">December</option>
    </select>

    <button class="add-table-box" id="addBtn">
      <span style="font-size:20px;line-height:1;">+</span>
      Add New Item
    </button>
  </div>

  <!-- Table -->
  <div class="card1">
    <div class="table-header">
      <h3>Incoming Project List</h3>
      <div class="table-count" id="projectCount">Loading...</div>
    </div>
    <div class="table-body">
      <table>
        <colgroup>
          <col style="width: 80px;" />
          <col style="width: 12%;" />
          <col style="width: 15%;" />
          <col style="width: 13%;" />
          <col style="width: 110px;" />
          <col style="width: 130px;" />
          <col style="width: 110px;" />
          <col style="width: 190px;" />
        </colgroup>
        <thead>
          <tr>
            <th>Item</th>
            <th>Project Name</th>
            <th>Type</th>
            <th>Sales Name</th>
            <th>PO Value</th>
            <th>PO Nos.</th>
            <th>Created</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody id="tableBody">
          <tr>
            <td colspan="8" class="loading-state">Loading data...</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</section>

<!-- Modal Add/Edit -->
<div class="modal-content" id="modalOverlay">
  <div class="modal">
    <h2 id="modalTitle">Add New Item</h2>
    <input type="hidden" id="editId" />
    <div class="form-bar">
      <div class="form-group2">
        <label>Item</label>
        <input type="text" id="fieldItem" placeholder="Enter Item No." />
      </div>
    </div>
    <div class="form-bar">
      <div class="form-group2 form-group1">
        <label>Project Name</label>
        <input type="text" id="fieldProjectName" placeholder="Enter project name" />
      </div>
    </div>
    <div class="form-bar">
      <div class="form-group2 form-group1">
        <label>Type</label>
        <div class="type-checkbox-group">
          <label class="type-checkbox-item"><input type="checkbox" name="projectType" value="1" /> BMS/SCADA</label>
          <label class="type-checkbox-item"><input type="checkbox" name="projectType" value="2" /> PME</label>
          <label class="type-checkbox-item"><input type="checkbox" name="projectType" value="3" /> CCTV</label>
          <label class="type-checkbox-item"><input type="checkbox" name="projectType" value="4" /> ACS</label>
          <label class="type-checkbox-item"><input type="checkbox" name="projectType" value="5" /> Installation</label>
          <label class="type-checkbox-item"><input type="checkbox" name="projectType" value="6" /> Engineer</label>
        </div>
      </div>
    </div>
    <div class="form-bar">
      <div class="form-group2">
        <label>Sales Name</label>
        <input type="text" id="fieldSalesName" placeholder="Enter sales name" />
      </div>
      <div class="form-group2">
        <label>PO Value</label>
        <input type="text" id="fieldPoValue" placeholder="Enter PO value" />
      </div>
    </div>
    <div class="form-bar">
      <div class="form-group2">
        <label>PO Nos.</label>
        <input type="text" id="fieldPoNos" placeholder="Enter PO number" />
      </div>
      <div class="form-group2">
        <label>Region</label>
        <select id="fieldRegion">
          <option value="">-- Select Region --</option>
          <option value="bangkok">Bangkok</option>
          <option value="central">Central</option>
          <option value="north">North</option>
          <option value="east">East</option>
          <option value="west">West</option>
          <option value="south">South</option>
        </select>
      </div>
    </div>
    <div class="form-bar" id="createdDateGroup" style="display:none;">
      <div class="form-group2">
        <label>Created Date</label>
        <input type="date" id="fieldCreatedAt" />
      </div>
    </div>
    <div class="modal-spacing">
      <button class="btn-cancel" id="cancelBtn">Cancel</button>
      <button class="btn-save" id="saveBtn">Save</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
  const BASE = '/incoming-project/api/projects';
  let allRows = [];

  const TYPE_NAMES = {
    1: 'BMS/SCADA',
    2: 'PME',
    3: 'CCTV',
    4: 'ACS',
    5: 'Installation',
    6: 'Engineer',
  };

  async function loadProjects() {
    try {
      const res = await fetch(BASE);
      const data = await res.json();
      if (!res.ok) throw new Error(data.message || `HTTP ${res.status}`);
      if (!Array.isArray(data)) throw new Error('Invalid response: ' + JSON.stringify(data).slice(0, 100));
      allRows = data;
      renderTable(allRows);
    } catch (err) {
      document.getElementById('tableBody').innerHTML =
        '<tr><td colspan="7" class="empty-state">Failed to load data: ' + err.message + '</td></tr>';
    }
  }

  function renderTypeBadges(types) {
    if (!types || types.length === 0) return '';
    return '<div class="type-badges">' +
      types.map((t) => `<span class="type-badge">${esc(t.name || TYPE_NAMES[t.id] || '')}</span>`).join('') +
      '</div>';
  }

  function renderTable(rows) {
    const tbody = document.getElementById('tableBody');
    const count = document.getElementById('projectCount');
    count.textContent = rows.length + ' record(s)';

    if (rows.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="empty-state">No data found</td></tr>';
      return;
    }

    tbody.innerHTML = rows.map((row) => `
      <tr>
        <td>${esc(row.item)}</td>
        <td><a href="/detail-project/${row.id}" class="project-name-link"><strong>${esc(row.project_name)}</strong></a></td>
        <td>${renderTypeBadges(row.types)}</td>
        <td>${esc(row.sales_name)}</td>
        <td>${esc(String(row.po_value ?? ''))}</td>
        <td>${esc(row.po_no)}</td>
        <td>${row.created_at ? new Date(row.created_at).toLocaleDateString('th-TH') : ''}</td>
        <td>
          <div class="button-spacing">
            <a href="/detail-project/${row.id}" class="btn-table btn-detail">Detail</a>
            <button class="btn-table btn-edit" onclick="openEdit(${row.id})">Edit</button>
            <button class="btn-table btn-destroy" onclick="deleteRow(${row.id})">Delete</button>
          </div>
        </td>
      </tr>
    `).join('');
  }

  function esc(str) {
    if (str == null) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  document.getElementById('searchInput').addEventListener('input', applyFilters);
  document.getElementById('filterStatus').addEventListener('change', applyFilters);

  function applyFilters() {
    const q = document.getElementById('searchInput').value.trim().toLowerCase();
    const month = document.getElementById('filterStatus').value;

    const filtered = allRows.filter((r) => {
      const matchSearch = !q ||
        String(r.item || '').toLowerCase().includes(q) ||
        (r.project_name || '').toLowerCase().includes(q) ||
        (r.sales_name || '').toLowerCase().includes(q);

      const matchMonth = !month ||
        (r.created_at && new Date(r.created_at).getMonth() + 1 === Number(month));

      return matchSearch && matchMonth;
    });

    renderTable(filtered);
  }

  const overlay = document.getElementById('modalOverlay');

  function openAdd() {
    document.getElementById('modalTitle').textContent = 'Add New Item';
    document.getElementById('editId').value = '';
    document.getElementById('createdDateGroup').style.display = 'none';
    clearFields();
    overlay.classList.add('open');
  }

  function openEdit(id) {
    const row = allRows.find((r) => r.id === id);
    if (!row) return;
    document.getElementById('modalTitle').textContent = 'Edit Item';
    document.getElementById('editId').value = id;
    document.getElementById('fieldItem').value = row.item || '';
    document.getElementById('fieldProjectName').value = row.project_name || '';
    document.getElementById('fieldSalesName').value = row.sales_name || '';
    document.getElementById('fieldPoValue').value = row.po_value || '';
    document.getElementById('fieldPoNos').value = row.po_no || '';
    document.getElementById('fieldRegion').value = row.region || '';

    const createdVal = row.created_at ? row.created_at.slice(0, 10) : '';
    document.getElementById('fieldCreatedAt').value = createdVal;
    document.getElementById('createdDateGroup').style.display = 'flex';

    const checkedIds = (row.types || []).map((t) => String(t.id));
    document.querySelectorAll('input[name="projectType"]').forEach((cb) => {
      cb.checked = checkedIds.includes(cb.value);
    });

    overlay.classList.add('open');
  }

  function clearFields() {
    ['fieldItem', 'fieldProjectName', 'fieldSalesName', 'fieldPoValue', 'fieldPoNos', 'fieldCreatedAt']
      .forEach((id) => { document.getElementById(id).value = ''; });
    document.querySelectorAll('input[name="projectType"]').forEach((cb) => { cb.checked = false; });
    document.getElementById('fieldRegion').value = '';
  }

  document.getElementById('cancelBtn').addEventListener('click', () => overlay.classList.remove('open'));
  overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.remove('open'); });

  document.getElementById('saveBtn').addEventListener('click', async () => {
    const id = document.getElementById('editId').value;
    const typeIds = Array.from(document.querySelectorAll('input[name="projectType"]:checked'))
      .map((cb) => Number(cb.value));

    const dto = {
      item: document.getElementById('fieldItem').value.trim(),
      project_name: document.getElementById('fieldProjectName').value.trim(),
      sales_name: document.getElementById('fieldSalesName').value.trim(),
      po_value: document.getElementById('fieldPoValue').value.trim() || null,
      po_no: document.getElementById('fieldPoNos').value.trim(),
      region: document.getElementById('fieldRegion').value,
      type_ids: typeIds,
    };
    if (id && document.getElementById('fieldCreatedAt').value) {
      dto.created_at = document.getElementById('fieldCreatedAt').value;
    }

    try {
      let res;
      if (id) {
        res = await fetch(`${BASE}/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dto),
        });
      } else {
        res = await fetch(BASE, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(dto),
        });
      }
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.message || `HTTP ${res.status}`);
      }
      showToast(id ? 'Item updated successfully' : 'Item added successfully');
      overlay.classList.remove('open');
      await loadProjects();
    } catch (err) {
      showToast('Error: ' + err.message);
    }
  });

  async function deleteRow(id) {
    const row = allRows.find((r) => r.id === id);
    const name = row ? row.project_name || row.item : id;
    if (!confirm(`Are you sure you want to delete "${name}"?`)) return;
    try {
      await fetch(`${BASE}/${id}`, { method: 'DELETE' });
      showToast('Item deleted successfully');
      await loadProjects();
    } catch (err) {
      showToast('Error: ' + err.message);
    }
  }

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(() => t.classList.remove('show'), 2800);
  }

  document.getElementById('addBtn').addEventListener('click', openAdd);
  loadProjects();
</script>
