<style>
  /* override default content padding — ต้องการเต็มหน้า */
  .main > .content,
  section.content { padding: 0 !important; }

  .chat-wrap {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 76px);
    background: var(--bg);
  }

  /* ── Messages ── */
  .chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 28px 32px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    scroll-behavior: smooth;
  }
  .chat-messages::-webkit-scrollbar { width: 5px; }
  .chat-messages::-webkit-scrollbar-track { background: transparent; }
  .chat-messages::-webkit-scrollbar-thumb { background: #ccd6e6; border-radius: 99px; }

  /* row */
  .msg-row {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    animation: msgIn 0.22s ease both;
  }
  .msg-row.user { flex-direction: row-reverse; }
  @keyframes msgIn {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* avatar */
  .msg-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px; font-weight: 700; flex-shrink: 0;
  }
  .msg-row.bot  .msg-avatar { background: var(--primary); color: #fff; }
  .msg-row.user .msg-avatar { background: #dbe8f8; color: var(--primary); }

  /* bubble wrapper — ควบคุมความกว้างที่นี่ */
  .msg-body {
    max-width: 65%;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }
  .msg-row.user .msg-body { align-items: flex-end; }

  /* bubble */
  .msg-bubble {
    width: fit-content;
    max-width: 100%;
    padding: 12px 16px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.6;
    box-shadow: 0 2px 8px rgba(30,58,95,0.07);
    overflow-wrap: break-word;
    word-break: break-word;
  }
  .msg-row.bot  .msg-bubble {
    background: var(--card);
    color: var(--text);
    border-bottom-left-radius: 4px;
  }
  .msg-row.user .msg-bubble {
    background: var(--primary);
    color: #fff;
    border-bottom-right-radius: 4px;
  }
  .msg-time {
    font-size: 10px;
    color: var(--muted);
    margin-top: 5px;
    padding: 0 4px;
  }
  .msg-row.user .msg-time { text-align: right; }

  /* quick replies */
  .quick-replies {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 10px;
    padding-left: 44px;
  }
  .quick-btn {
    padding: 7px 16px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--primary);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.18s;
  }
  .quick-btn:hover { background: var(--primary); color: #fff; border-color: var(--primary); }

  /* typing indicator */
  .typing-row { display: none; }
  .typing-row.show { display: flex; }
  .typing-dots {
    display: flex; align-items: center; gap: 4px;
    padding: 12px 16px;
    background: var(--card);
    border-radius: 18px;
    border-bottom-left-radius: 4px;
    box-shadow: 0 2px 8px rgba(30,58,95,0.07);
  }
  .typing-dots span {
    width: 7px; height: 7px; border-radius: 50%;
    background: #a0b4cc;
    animation: bounce 1.2s infinite ease-in-out;
  }
  .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce {
    0%,80%,100% { transform: translateY(0); }
    40%         { transform: translateY(-7px); }
  }

  /* ── Input bar ── */
  .chat-input-bar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 32px 20px;
    background: var(--card);
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 16px rgba(30,58,95,0.05);
  }
  .chat-input {
    flex: 1;
    height: 48px;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 0 18px;
    font-size: 14px;
    color: var(--text);
    background: var(--bg);
    outline: none;
    transition: border 0.2s;
    font-family: inherit;
  }
  .chat-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(74,144,226,0.1); }
  .chat-send-btn {
    width: 48px; height: 48px;
    border-radius: 14px;
    border: none;
    background: var(--primary);
    color: #fff;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.18s;
  }
  .chat-send-btn:hover { opacity: 0.88; }
  .chat-send-btn svg { width: 20px; height: 20px; }
</style>

<div class="chat-wrap">

  <!-- Messages -->
  <div class="chat-messages" id="chatMessages">

    <!-- Welcome -->
    <div class="msg-row bot">
      <div class="msg-avatar">R</div>
      <div class="msg-body">
        <div class="msg-bubble">สวัสดีครับ! ผมคือผู้ช่วย Rojpaiboon Dashboard<br>มีอะไรให้ช่วยไหมครับ?</div>
        <div class="msg-time">เพิ่งเริ่ม</div>
      </div>
    </div>

    <!-- Quick replies -->
    <div class="quick-replies" id="quickReplies">
      <button class="quick-btn" onclick="sendQuick(this)">โปรเจคทั้งหมด</button>
      <button class="quick-btn" onclick="sendQuick(this)">สถานะงาน</button>
      <button class="quick-btn" onclick="sendQuick(this)">ทีมทั้งหมด</button>
      <button class="quick-btn" onclick="sendQuick(this)">การชำระเงิน</button>
      <button class="quick-btn" onclick="sendQuick(this)">วิธีใช้งาน</button>
    </div>

  </div>

  <!-- Typing indicator -->
  <div class="msg-row bot typing-row" id="typingRow" style="padding: 0 32px 10px;">
    <div class="msg-avatar">R</div>
    <div class="typing-dots">
      <span></span><span></span><span></span>
    </div>
  </div>

  <!-- Input bar -->
  <div class="chat-input-bar">
    <input
      type="text"
      class="chat-input"
      id="chatInput"
      placeholder="พิมพ์ข้อความ..."
      autocomplete="off"
    />
    <button class="chat-send-btn" id="sendBtn">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M22 2L11 13M22 2L15 22L11 13M22 2L2 9L11 13"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

</div>

<script>
const RESPONSES = [
