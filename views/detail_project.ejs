
<style>
   
    /* =============================================
       HEADER CARD
    ============================================= */
    .profile-header {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow-md);
      padding: 28px 32px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
      margin-bottom: 24px;
      animation: fadeUp 0.4s ease both;
      border-left: 5px solid var(--accent);
    }

    .profile-left { display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }

    .profile-avatar {
      width: 72px; height: 72px; border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 22px; font-weight: 800;
      flex-shrink: 0;
      box-shadow: 0 6px 18px rgba(30,58,95,0.22);
    }

    .profile-name {
      font-size: 24px; font-weight: 800;
      color: var(--primary); line-height: 1.2;
      margin-bottom: 8px;
    }

    .profile-contacts { display: flex; gap: 20px; flex-wrap: wrap; }
    .contact-item {
      display: flex; align-items: center; gap: 7px;
      font-size: 13px; color: var(--muted);
    }
    .contact-item svg { color: var(--accent); flex-shrink: 0; }
    .contact-item span { color: #2e4a6a; }

    .profile-actions { display: flex; gap: 10px; flex-wrap: wrap; }

    .btn {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 18px; border-radius: var(--radius-sm);
      font-size: 14px; font-weight: 600;
      transition: var(--transition);
      text-decoration: none;
    }
    .btn-outline {
      border: 1.5px solid var(--border);
      background: var(--card); color: var(--primary);
    }
    .btn-outline:hover {
      border-color: var(--accent); color: var(--accent);
      transform: translateY(-1px);
    }
    .btn-back {
      background: rgba(30,58,95,0.07);
      color: var(--primary);
      border: none;
    }
    .btn-back:hover {
      background: rgba(30,58,95,0.13);
      transform: translateY(-1px);
    }

    /* =============================================
       Main Grid
    ============================================= */
    .detail-grid {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 20px;
    }

    .col-left  { display: flex; flex-direction: column; gap: 20px; }
    .col-right { display: flex; flex-direction: column; gap: 20px; }

    .card {
      background: var(--card);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
      animation: fadeUp 0.45s ease both;
    }

    .card-header {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 18px 22px 16px;
      border-bottom: 1px solid #edf2f7;
      gap: 10px; flex-wrap: wrap;
    }
    .card-title {
      display: flex; align-items: center; gap: 9px;
      font-size: 15px; font-weight: 700; color: var(--primary);
    }
    .card-title svg { color: var(--accent); }
    .card-body { padding: 20px 22px; }

    /* =============================================
       A. AI Insights
    ============================================= */
    .ai-card-wrap {
      padding: 2px;
      border-radius: calc(var(--radius) + 2px);
      background: linear-gradient(135deg, #4A90E2 0%, #7C5CBF 50%, #35B37E 100%);
      box-shadow: 0 6px 24px rgba(124,92,191,0.18);
      animation: fadeUp 0.45s ease both;
      animation-delay: 0.08s;
    }
    .ai-card-inner {
      background: var(--card);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .ai-header {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 18px 22px 14px;
      border-bottom: 1px solid #edf2f7;
      background: linear-gradient(135deg, #f8f0ff 0%, #eef4ff 100%);
    }
    .ai-title {
      display: flex; align-items: center; gap: 9px;
      font-size: 15px; font-weight: 700; color: var(--primary);
    }
    .ai-badge {
      padding: 4px 12px; border-radius: 999px;
      font-size: 11px; font-weight: 700;
      background: linear-gradient(135deg, #7C5CBF, #4A90E2);
      color: #fff; letter-spacing: 0.3px;
    }

    .ai-body { padding: 20px 22px; }
    .ai-values {
      display: grid; grid-template-columns: repeat(2,1fr);
      gap: 12px; margin-bottom: 18px;
    }
    .ai-val-box {
      padding: 14px; border-radius: 12px;
      border: 1px solid var(--border);
      background: #fafcff;
    }
    .ai-val-box .label { font-size: 11px; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.4px; }
    .ai-val-box .value { font-size: 18px; font-weight: 800; color: var(--primary); word-break: break-word; }
    .ai-val-box .sub   { font-size: 11px; color: var(--muted); margin-top: 3px; }

    .ai-insight-box {
      padding: 14px 16px;
      border-radius: 12px;
      background: linear-gradient(135deg, #f3edff 0%, #e8f0ff 100%);
      border-left: 4px solid #7C5CBF;
      display: flex; gap: 12px; align-items: flex-start;
    }
    .ai-insight-box svg { color: #7C5CBF; flex-shrink: 0; margin-top: 1px; }
    .ai-insight-text .title { font-size: 13px; font-weight: 700; color: #7C5CBF; margin-bottom: 4px; }
    .ai-insight-text .body  { font-size: 12px; color: #4a3870; line-height: 1.55; }

    .ai-ring-wrap {
      display: flex; flex-direction: column; align-items: center;
      padding: 6px 0 20px;
    }
    .ai-ring-label {
      font-size: 11px; font-weight: 700; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.5px; margin-top: 10px;
    }
    .ai-ring-svg { position: relative; }
    .ai-ring-bg   { fill: none; stroke: #edf2f7; stroke-width: 10; }
    .ai-ring-fill {
      fill: none; stroke-width: 10;
      stroke: url(#ringGrad);
      stroke-linecap: round;
      transform: rotate(-90deg); transform-origin: 50% 50%;
      transition: stroke-dashoffset 1s ease;
    }
    .ai-ring-pct {
      font-size: 26px; font-weight: 900; fill: var(--primary);
      dominant-baseline: middle; text-anchor: middle;
    }
    .ai-ring-sub {
      font-size: 10px; fill: var(--muted);
      dominant-baseline: middle; text-anchor: middle;
    }
    @keyframes ringDraw {
      from { stroke-dashoffset: 314; }
    }

    /* =============================================
       B. Documents
    ============================================= */
    .doc-cat-tabs {
      display: flex; gap: 3px;
      background: #eef3f9; border-radius: 10px; padding: 3px;
    }
    .doc-cat-btn {
      padding: 5px 14px; border-radius: 8px; font-size: 12px; font-weight: 600;
      border: none; background: transparent; color: var(--muted); cursor: pointer;
      transition: all 0.18s; white-space: nowrap;
    }
    .doc-cat-btn.active {
      background: #fff; color: var(--primary);
      box-shadow: 0 2px 6px rgba(30,58,95,0.1);
    }
    .doc-cat-btn:not(.active):hover { color: var(--primary); background: rgba(255,255,255,0.5); }
    .doc-progress-wrap {
      display: flex; align-items: center; gap: 10px;
    }
    .doc-progress-bar {
      flex: 1; height: 6px; border-radius: 999px;
      background: #e8f0f9; overflow: hidden;
    }
    .doc-progress-fill {
      height: 100%; border-radius: 999px;
      background: linear-gradient(90deg, var(--accent), #35B37E);
      transition: width 0.4s ease;
    }
    .doc-progress-text {
      font-size: 12px; font-weight: 700;
      color: var(--primary); white-space: nowrap;
    }

    .doc-list { display: flex; flex-direction: column; }
    .doc-row {
      padding: 12px 0;
      border-bottom: 1px solid #f0f4f9;
    }
    .doc-row:last-child { border-bottom: none; }
    .doc-row-top {
      display: flex; align-items: center;
      justify-content: space-between; gap: 8px;
    }
    .doc-name {
      font-size: 13px; font-weight: 600;
      color: var(--primary); flex: 1;
    }
    .doc-required {
      font-size: 10px; color: #c0392b;
      font-weight: 600; margin-left: 4px;
    }
    .doc-actions { display: flex; align-items: center; gap: 6px; }

    .btn-upload-sm {
      display: flex; align-items: center; gap: 5px;
      padding: 5px 12px; border-radius: 8px;
      background: #eef4fb; color: var(--primary);
      font-size: 12px; font-weight: 600;
      border: 1.5px dashed #b0cce8;
      cursor: pointer; transition: var(--transition);
    }
    .btn-upload-sm:hover {
      background: #ddeaf7; border-color: var(--accent);
      color: var(--accent);
    }

    .doc-files { margin-top: 8px; display: flex; flex-direction: column; gap: 4px; }
    .doc-file-item {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 6px 10px; border-radius: 8px;
      background: #f4f8fc; font-size: 12px;
    }
    .doc-file-name {
      display: flex; align-items: center; gap: 6px;
      color: var(--text); font-weight: 500; flex: 1;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .doc-file-name svg { color: var(--accent); flex-shrink: 0; }
    .doc-file-actions { display: flex; gap: 6px; flex-shrink: 0; }
    .btn-file-action {
      padding: 3px 8px; border-radius: 6px;
      font-size: 11px; font-weight: 600;
      border: none; cursor: pointer; transition: var(--transition);
    }
    .btn-download { background: #e8f3ff; color: #1d5fa8; }
    .btn-download:hover { background: #cce3ff; }
    .btn-delete { background: #ffeaea; color: #c0392b; }
    .btn-delete:hover { background: #ffd0d0; }

    .doc-rejected-reason {
      margin-top: 6px; padding: 6px 10px;
      background: rgba(228,87,87,0.07);
      border-left: 3px solid #e45757;
      border-radius: 0 6px 6px 0;
      font-size: 11px; color: #c0392b;
    }

    /* status badge variants for docs */
    .ds-missing  { background: rgba(244,166,42,0.14); color: #9a6000; }
    .ds-uploaded { background: rgba(74,144,226,0.14); color: #1d5fa8; }
    .ds-approved { background: rgba(53,179,126,0.13); color: #1a7a54; }
    .ds-rejected { background: rgba(228,87,87,0.12);  color: #c0392b; }

    .btn-upload {
      display: flex; align-items: center; gap: 7px;
      padding: 10px 18px; border-radius: var(--radius-sm);
      background: #eef4fb; color: var(--primary);
      font-size: 13px; font-weight: 600;
      border: 1.5px dashed #b0cce8;
      transition: var(--transition);
    }
    .btn-upload:hover {
      background: #ddeaf7; border-color: var(--accent);
      color: var(--accent); transform: translateY(-1px);
    }

    /* =============================================
       C. Info Grid
    ============================================= */
    .info-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0;
    }
    .info-item {
      padding: 14px 0;
      border-bottom: 1px solid #f0f4f9;
    }
    .info-item:nth-child(odd)  { padding-right: 20px; border-right: 1px solid #f0f4f9; }
    .info-item:nth-child(even) { padding-left: 20px; }
    .info-item:nth-last-child(-n+3) { border-bottom: none; }

    .info-label {
      font-size: 11px; color: var(--muted);
      text-transform: uppercase; letter-spacing: 0.5px;
      margin-bottom: 5px;
    }
    .info-value { font-size: 14px; color: var(--text); font-weight: 600; }
    .info-value.success { color: var(--text); }

    /* =============================================
       D. Related Items Table
    ============================================= */
    .related-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    .related-table th {
      text-align: left;
      padding: 10px 14px;
      background: #f4f8fc;
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      font-weight: 600;
      border-bottom: 1px solid #edf2f7;
    }
    .related-table td {
      padding: 12px 14px;
      border-bottom: 1px solid #f0f4f9;
      color: var(--text);
    }
    .related-table tr:last-child td { border-bottom: none; }
    .related-table tr.current-row td { background: #f0f7ff; }
    .related-table tr:hover td { background: #fbfdff; }
    .related-table a { color: var(--accent); text-decoration: none; font-weight: 600; }
    .related-table a:hover { color: var(--secondary); }

    .empty-related {
      text-align: center;
      padding: 32px;
      color: var(--muted);
      font-size: 13px;
    }

    /* =============================================
       Animation
    ============================================= */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .col-left  .card:nth-child(1) { animation-delay: 0.15s; }
    .col-right .card:nth-child(1) { animation-delay: 0.20s; }
    .col-right .card:nth-child(2) { animation-delay: 0.25s; }

  

    /* Status badges */
    .badge {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 4px 10px; border-radius: 999px;
      font-size: 11px; font-weight: 600; white-space: nowrap;
    }
    .badge::before { content:""; width:6px; height:6px; border-radius:50%; background:currentColor; }
    .b-completed  { background: rgba(53,179,126,0.13); color: #1a7a54; }
    .b-processing { background: rgba(74,144,226,0.14); color: #1d5fa8; }
    .b-blocked    { background: rgba(228,87,87,0.12);  color: #c0392b; }
    .b-pending    { background: rgba(244,166,42,0.14); color: #9a6000; }

    .ts-overdue      { background: rgba(220,53,69,0.12);  color: #b91c1c; }
    .ts-near_deadline{ background: rgba(234,179,8,0.13);  color: #8a6400; }
    .ts-has_time     { background: rgba(53,179,126,0.12); color: #1a7a54; }
    .ts-just_started { background: rgba(65,121,191,0.12); color: #2a5fa0; }

    /* Responsive */
    @media (max-width: 1100px) {
      .detail-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 768px) {
      .main         { padding: 18px; }
      .topbar       { padding: 14px 18px; height: auto; flex-direction: column; align-items: flex-start; gap: 10px; }
      .profile-header { padding: 20px; }
      .info-grid    { grid-template-columns: 1fr; }
      .info-item:nth-child(odd) { border-right: none; padding-right: 0; }
      .info-item:nth-child(even){ padding-left: 0; }
      .info-item:nth-last-child(-n+2) { border-bottom: 1px solid #f0f4f9; }
      .info-item:last-child { border-bottom: none; }
      .ai-values { grid-template-columns: 1fr; }
    }
</style>


<section class="content">
<!-- ============== HEADER CARD ============== -->
<div class="profile-header">
  <div class="profile-left">
    <div class="profile-avatar"><%= project.avatarText %></div>
    <div class="profile-info">
      <div class="profile-name"><%= project.projectName %></div>
      <div class="profile-contacts">

        <div class="contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Start: <%= project.dateIn %></span>
        </div>
        <div class="contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span>Sales: <%= project.salesName %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="profile-actions">
    <span class="badge <%= project.statusCls %>" style="font-size:13px;padding:6px 14px;"><%= project.statusLabel %></span>
    <a href="javascript:history.back()" class="btn btn-back">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back
    </a>
  </div>
</div>

<!-- ============== MAIN GRID ============== -->
<div class="detail-grid">

  <!-- ========== LEFT COLUMN ========== -->
  <div class="col-left">

    <!-- AI Summary Card -->
    
    <div class="ai-card-wrap">
            <div class="ai-card-inner">
              <div class="ai-header">
                <div class="ai-title">
                  <!-- ไอคอน AI sparkle -->
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3z"/>
                  </svg>
                  AI Analytics
                </div>
                <span class="ai-badge">AI Powered</span>
              </div>

              <div class="ai-body">

                <!-- Progress Ring -->
                <div class="ai-ring-wrap">
                  <svg class="ai-ring-svg" width="120" height="120" viewBox="0 0 120 120">
                    <defs>
                      <linearGradient id="ringGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                        <stop offset="0%"   stop-color="#4A90E2"/>
                        <stop offset="50%"  stop-color="#7C5CBF"/>
                        <stop offset="100%" stop-color="#35B37E"/>
                      </linearGradient>
                    </defs>
                    <circle class="ai-ring-bg"   cx="60" cy="60" r="50"/>
                    <circle class="ai-ring-fill" cx="60" cy="60" r="50"
                      stroke-dasharray="314"
                      stroke-dashoffset="78.5"
                      style="animation: ringDraw 1.2s ease both;"/>
                    <text class="ai-ring-pct" x="60" y="56">75%</text>
                    <text class="ai-ring-sub"  x="60" y="72">Overall</text>
                  </svg>
                  <div class="ai-ring-label">Project Progress</div>
                </div>
                <!-- Value boxes -->
                <div class="ai-values">
                  <div class="ai-val-box">
                    <div class="label">Total Tasks</div>
                    <div class="value"><%= tasks.length %></div>
                    <div class="sub">Tasks in this project</div>
                  </div>
                  <div class="ai-val-box">
                    <div class="label">Status</div>
                    <div class="value" style="font-size:15px;"><%= project.statusLabel %></div>
                    <div class="sub">Current project status</div>
                  </div>
                </div>

                <!-- Teams box -->
                <div class="ai-insight-box">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                  <div class="ai-insight-text">
                    <div class="title">Assigned Teams</div>
                    <div class="body">
                      <% if (teams.length === 0) { %>
                        No team assigned yet.
                      <% } else { %>
                        <%= teams.map(function(t){ return t.team_name; }).join(', ') %>
                      <% } %>
                    </div>
                  </div>
                </div>

              </div>
            </div>
          </div>
    <!-- Documents Card -->
    <div class="card" style="animation-delay:0.18s;">
      <div class="card-header" style="flex-wrap:wrap;gap:10px;">
        <div class="card-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Documents
        </div>
        <div class="doc-cat-tabs">
          <button class="doc-cat-btn active" data-cat="all">All</button>
          <button class="doc-cat-btn" data-cat="engineer_task">Engineer Tasks</button>
          <button class="doc-cat-btn" data-cat="draft">Draft</button>
        </div>
        <div class="doc-progress-wrap" style="min-width:120px;">
          <div class="doc-progress-bar">
            <div class="doc-progress-fill" id="docProgressFill" style="width:<%= progress.total > 0 ? Math.round(progress.uploaded / progress.total * 100) : 0 %>%"></div>
          </div>
          <span class="doc-progress-text" id="docProgressText"><%= progress.uploaded %>/<%= progress.total %></span>
        </div>
      </div>

      <div class="card-body" style="padding:0 22px 8px;">
        <% if (checklist.length === 0) { %>
          <p style="text-align:center;color:var(--muted);padding:28px 0;font-size:13px;">No document types found</p>
        <% } else { %>
        <div class="doc-list">
          <% checklist.forEach(function(doc) {
            const statusLabel = { missing:'Pending', uploaded:'Uploaded', approved:'Approved', rejected:'Rejected' }[doc.status] || doc.status;
            const statusCls   = { missing:'ds-missing', uploaded:'ds-uploaded', approved:'ds-approved', rejected:'ds-rejected' }[doc.status] || '';
          %>
          <div class="doc-row" data-cat="<%= doc.category %>">
            <div class="doc-row-top">
              <div class="doc-name">
                <%= doc.typeName %>
                <% if (doc.isRequired) { %><span class="doc-required">*</span><% } %>
              </div>
              <div class="doc-actions">
                <span class="badge <%= statusCls %>"><%= statusLabel %></span>
                <label class="btn-upload-sm" style="margin:0;">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14"/></svg>
                  Upload
                  <input type="file" hidden multiple
                    data-project-id="<%= project.id %>"
                    data-type-id="<%= doc.typeId %>"
                    onchange="uploadDoc(this)">
                </label>
              </div>
            </div>

            <% if (doc.status === 'rejected' && doc.rejectedReason) { %>
              <div class="doc-rejected-reason">Reason: <%= doc.rejectedReason %></div>
            <% } %>

            <% if (doc.files.length > 0) { %>
            <div class="doc-files">
              <% doc.files.forEach(function(f) { %>
              <div class="doc-file-item">
                <div class="doc-file-name">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                  <%= f.filename %>
                </div>
                <div class="doc-file-actions">
                  <a href="/detail-project/documents/file/<%= f.id %>/download" class="btn-file-action btn-download">Download</a>
                  <button class="btn-file-action btn-delete" onclick="deleteDoc(<%= f.id %>, this)">Delete</button>
                </div>
              </div>
              <% }); %>
            </div>
            <% } %>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>
    </div>

  </div>

  <!-- ========== RIGHT COLUMN ========== -->
  <div class="col-right">

    <!-- Info Grid Card -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          Project Information
        </div>
      </div>
      <div class="card-body" style="padding-bottom:8px;">
        <div class="info-grid">

          <div class="info-item">
            <div class="info-label">Project Name</div>
            <div class="info-value"><%= project.projectName %></div>
          </div>
          <div class="info-item">
            <div class="info-label">Item</div>
            <div class="info-value"><%= project.item %></div>
          </div>

          <div class="info-item">
            <div class="info-label">Start Date</div>
            <div class="info-value"><%= project.dateIn %></div>
          </div>
          <div class="info-item">
            <div class="info-label">End Date</div>
            <div class="info-value"><%= project.endDate %></div>
          </div>

          <div class="info-item">
            <div class="info-label">Sales Name</div>
            <div class="info-value"><%= project.salesName %></div>
          </div>
          <div class="info-item">
            <div class="info-label">PO No.</div>
            <div class="info-value"><%= project.poNo %></div>
          </div>

          <div class="info-item">
            <div class="info-label">PO Value</div>
            <div class="info-value success"><%= project.poValue %></div>
          </div>
          <div class="info-item">
            <div class="info-label">Status</div>
            <div class="info-value"><%= project.statusLabel %></div>
          </div>

          <% if (project.types && project.types.length) { %>
          <div class="info-item" style="grid-column:span 2;border-bottom:none;">
            <div class="info-label">Project Types</div>
            <div class="info-value" style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;">
              <% project.types.forEach(function(type) { %>
                <span style="display:inline-block;background:#e8f1fb;color:#2a5fa0;font-size:12px;font-weight:700;padding:3px 10px;border-radius:999px;"><%= type %></span>
              <% }); %>
            </div>
          </div>
          <% } %>

        </div>
      </div>
    </div>

    <!-- Tasks Card -->
    <div class="card">
      <div class="card-header">
        <div class="card-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          Tasks
        </div>
        <span style="font-size:12px;color:var(--muted);"><%= tasks.length %> tasks</span>
      </div>
      <% if (tasks.length === 0) { %>
        <div class="empty-related">No tasks assigned to this project yet.</div>
      <% } else { %>
        <table class="related-table">
          <thead>
            <tr>
              <th>Task Name</th>
              <th>Assigned To</th>
              <th>End Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% tasks.forEach(function(t) { %>
            <tr>
              <td>
                <div style="font-weight:600;color:var(--primary)"><%= t.task_name %></div>
                <% if (t.task_description) { %>
                  <div style="font-size:11px;color:#7a99b8;margin-top:2px;"><%= t.task_description %></div>
                <% } %>
              </td>
              <td><%= t.user_name %></td>
              <td><%= t.end_date %></td>
              <td><span class="badge ts-badge ts-<%= t.status %>"><%= t.statusLabel %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

  </div>
</div>
</section>

<script>
// ── Document category filter ──────────────────────────────
(function() {
  const CHECKLIST = <%- JSON.stringify(checklist) %>;

  document.querySelectorAll('.doc-cat-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.doc-cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      const cat = btn.dataset.cat;
      const rows = document.querySelectorAll('.doc-row');
      rows.forEach(row => {
        row.style.display = (cat === 'all' || row.dataset.cat === cat) ? '' : 'none';
      });

      // Recalc progress for selected category
      const items = cat === 'all'
        ? CHECKLIST
        : CHECKLIST.filter(d => d.category === cat);
      const total    = items.filter(d => d.isRequired).length;
      const uploaded = items.filter(d => d.isRequired && d.status !== 'missing').length;
      const pct = total > 0 ? Math.round(uploaded / total * 100) : 0;
      document.getElementById('docProgressFill').style.width = pct + '%';
      document.getElementById('docProgressText').textContent = uploaded + '/' + total;
    });
  });
})();

async function uploadDoc(input) {
  const projectId = input.dataset.projectId;
  const typeId    = input.dataset.typeId;
  const files     = input.files;
  if (!files.length) return;

  for (const file of files) {
    const fd = new FormData();
    fd.append('file', file);
    const res = await fetch(`/detail-project/${projectId}/documents/${typeId}/upload`, {
      method: 'POST', body: fd,
    });
    if (!res.ok) { alert('Upload failed: ' + file.name); return; }
  }
  location.reload();
}

async function deleteDoc(fileId, btn) {
  if (!confirm('Are you sure you want to delete this file?')) return;
  btn.disabled = true;
  const res = await fetch(`/detail-project/documents/file/${fileId}`, { method: 'DELETE' });
  if (res.ok) location.reload();
  else { alert('Delete failed'); btn.disabled = false; }
}
</script>