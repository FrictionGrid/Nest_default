<style>
  /* ── Summary Cards ─────────────────────────────── */
  .db-stat-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    margin-bottom: 26px;
  }
  .db-stat {
    background: var(--card);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 20px 22px;
    border-top: 4px solid transparent;
    animation: fadeUp 0.4s ease both;
  }
  .db-stat h4 { font-size: 13px; color: var(--muted); margin-bottom: 8px; font-weight: 600; }
  .db-stat .val { font-size: 36px; font-weight: 800; color: var(--text); line-height: 1; }
  .db-stat p { font-size: 12px; color: var(--muted); margin-top: 6px; }
  .db-stat.s-total      { border-color: #1e3a5f; }
  .db-stat.s-incomplete { border-color: #4a90e2; }
  .db-stat.s-general    { border-color: #EAB308; }
  .db-stat.s-near       { border-color: #F97316; }
  .db-stat.s-overdue    { border-color: #dc3545; }

  /* ── Two-col grid ──────────────────────────────── */
  .db-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 1100px) { .db-grid { grid-template-columns: 1fr; } }

  @media (max-width: 768px) {
    .db-stat-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
    .db-stat { padding: 14px 16px; }
    .db-stat .val { font-size: 26px; }
    .mini-grid { grid-template-columns: 1fr; }
    .task-item { flex-wrap: wrap; }
    .db-card-body { padding: 12px 14px 16px; }
  }

  @media (max-width: 480px) {
    .db-stat-grid { grid-template-columns: 1fr; }
  }

  /* ── Card base ─────────────────────────────────── */
  .db-card {
    background: var(--card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    overflow: hidden;
    animation: fadeUp 0.45s ease both;
  }
  .db-card-hd {
    padding: 18px 22px 14px;
    border-bottom: 1px solid #eef2f8;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .db-card-hd h3 { font-size: 15px; font-weight: 700; color: var(--text); }
  .db-card-body { padding: 16px 22px 20px; }

  /* ── Task list ─────────────────────────────────── */
  .task-list { display: flex; flex-direction: column; gap: 12px; }
  .task-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid #eef2f8;
    border-radius: 12px;
    background: #fbfcfe;
    transition: border-color 0.2s;
  }
  .task-item:hover { border-color: #c5d8ef; }
  .task-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }
  .dot-general { background: #4a90e2; }
  .dot-near    { background: #EAB308; }
  .dot-urgent  { background: #F97316; }
  .dot-overdue { background: #dc3545; }
  .task-info { flex: 1; min-width: 0; }
  .task-name { font-size: 14px; font-weight: 700; color: var(--text); }
  .task-meta { font-size: 12px; color: var(--muted); margin-top: 3px; }

  /* ── Task badges ───────────────────────────────── */
  .task-badge {
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px; white-space: nowrap;
  }
  .tb-in_progress { background: #e8f1fb; color: #2a5fa0; }
  .tb-problem     { background: rgba(226,169,59,0.13); color: #8a6400; }
  .tb-completed   { background: #dff5e7; color: #1a7a54; }

  /* ── Priority badges ───────────────────────────── */
  .pr-badge {
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px; white-space: nowrap;
  }
  .pr-general { background: rgba(65,121,191,0.1);  color: #2a5fa0; }
  .pr-near    { background: rgba(234,179,8,0.15);   color: #7a5c00; }
  .pr-urgent  { background: rgba(249,115,22,0.15); color: #b84600; }
  .pr-overdue { background: #dc3545; color: #fff; }

  /* ── Progress input ────────────────────────────── */
  .task-progress-wrap {
    display: flex; align-items: center; gap: 8px; margin-top: 8px;
  }
  .task-progress-bar {
    flex: 1; height: 6px; background: #e8f0f9;
    border-radius: 999px; overflow: hidden;
  }
  .task-progress-fill {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, #4a90e2, #35B37E);
    transition: width 0.4s ease;
  }
  .task-progress-input {
    width: 52px; height: 30px;
    border: 1.5px solid #cdd9e8; border-radius: 8px;
    padding: 0 8px; font-size: 13px; font-weight: 700;
    color: var(--primary); text-align: center;
    outline: none; transition: border 0.2s;
    background: #fff;
  }
  .task-progress-input:focus { border-color: #4a90e2; }
  .task-progress-label {
    font-size: 12px; font-weight: 700; color: var(--muted);
    white-space: nowrap;
  }

  /* ── Action buttons ────────────────────────────── */
  .btn-complete {
    font-size: 12px; font-weight: 700;
    padding: 6px 16px; border-radius: 8px;
    border: none; cursor: pointer;
    background: #1d8f56; color: #fff;
    box-shadow: 0 2px 6px rgba(29,143,86,0.25);
    transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
    white-space: nowrap;
  }
  .btn-complete:hover { background: #166040; box-shadow: 0 3px 10px rgba(29,143,86,0.35); transform: translateY(-1px); }
  .btn-complete:active { transform: translateY(0); }
  .btn-complete:disabled { background: #9ec9b0; box-shadow: none; cursor: default; transform: none; }

  .btn-problem {
    font-size: 12px; font-weight: 700;
    padding: 6px 16px; border-radius: 8px;
    border: none; cursor: pointer;
    background: #fff7e6; color: #8a6400;
    box-shadow: 0 2px 6px rgba(226,169,59,0.2);
    transition: background 0.2s, box-shadow 0.2s, transform 0.1s;
    white-space: nowrap;
  }
  .btn-problem:hover { background: #ffecc2; box-shadow: 0 3px 10px rgba(226,169,59,0.3); transform: translateY(-1px); }
  .btn-problem:active { transform: translateY(0); }
  .btn-problem:disabled { background: #f5f0e8; color: #c9b47a; box-shadow: none; cursor: default; transform: none; }

  /* ── Weekly Goal ───────────────────────────────── */
  .goal-wrap { padding: 4px 0; }
  .goal-meta {
    display: flex; justify-content: space-between;
    font-size: 13px; color: var(--muted); margin-bottom: 10px;
  }
  .goal-bar {
    width: 100%; height: 10px;
    background: #eef2f8; border-radius: 999px; overflow: hidden;
    margin-bottom: 20px;
  }
  .goal-fill {
    height: 100%;
    background: linear-gradient(90deg, #1e3a5f, #4a90e2);
    border-radius: 999px;
    transition: width 0.6s ease;
  }
  .mini-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .mini-card {
    padding: 14px 16px;
    border-radius: 12px;
    background: #f9fbfd;
    border: 1px solid #eef2f8;
  }
  .mini-card span { font-size: 12px; color: var(--muted); display: block; margin-bottom: 6px; }
  .mini-card strong { font-size: 22px; font-weight: 800; color: var(--text); }

  /* ── Project table ─────────────────────────────── */
  .db-table-wrap { overflow-x: auto; }
  .db-table { width: 100%; border-collapse: collapse; min-width: 600px; }
  .db-table thead th {
    text-align: left; padding: 12px 16px;
    background: #f4f7fb; color: var(--primary);
    font-size: 13px; font-weight: 700;
    border-bottom: 1px solid #e6edf5;
  }
  .db-table tbody td {
    padding: 14px 16px;
    font-size: 13px; color: #495565;
    border-bottom: 1px solid #f0f4fa;
  }
  .db-table tbody tr:hover { background: #f9fbfe; }
  .team-chip {
    display: inline-block;
    background: #e8f1fb; color: #2a5fa0;
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px;
  }
  .st-badge {
    display: inline-block;
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px;
  }
  .st-in_progress { background: #e8f1fb; color: #2a5fa0; }
  .st-delayed     { background: #fde8e8; color: #b91c1c; }
  .st-completed   { background: #dff5e7; color: #1a7a54; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<section class="content">

  <!-- ── Summary Cards ─────────────────────────── -->
  <div class="db-stat-grid">
    <div class="db-stat s-total">
      <h4>All Tasks</h4>
      <div class="val"><%= summary.total %></div>
      <p>Excluding completed</p>
    </div>
    <div class="db-stat s-incomplete">
      <h4>In Progress</h4>
      <div class="val"><%= summary.not_due %></div>
      <p>More than 7 days left</p>
    </div>
    <div class="db-stat s-general">
      <h4>Warning</h4>
      <div class="val"><%= summary.general %></div>
      <p>7 days left</p>
    </div>
    <div class="db-stat s-near">
      <h4>Critical</h4>
      <div class="val"><%= summary.near %></div>
      <p>3 days left</p>
    </div>
    <div class="db-stat s-overdue">
      <h4>Overdue</h4>
      <div class="val"><%= summary.overdue %></div>
      <p>Past due date</p>
    </div>
  </div>

  <!-- ── Task List (full width) ───────────────── -->
  <div class="db-card" style="margin-bottom:24px;">
    <div class="db-card-hd">
      <h3>Task List</h3>
      <span style="font-size:12px;color:var(--muted);"><%= tasks.length %> items</span>
    </div>
    <div class="db-card-body">
      <% if (!tasks || tasks.length === 0) { %>
        <div style="text-align:center;color:var(--muted);padding:30px 0;font-size:14px;">No tasks found</div>
      <% } else { %>
      <div class="task-list">
        <% tasks.filter(t => t.status !== 'completed').forEach(function(t) {
          const prMap = {
            general: { dotCls:'dot-general', badgeCls:'pr-general', label:'In Progress' },
            near:    { dotCls:'dot-near',    badgeCls:'pr-near',    label:'Warning'  },
            urgent:  { dotCls:'dot-urgent',  badgeCls:'pr-urgent',  label:'Critical' },
            overdue: { dotCls:'dot-overdue', badgeCls:'pr-overdue', label:'Overdue'     },
          };
          const pr = prMap[t.priority] || prMap.general;
        %>
        <div class="task-item">
          <div class="task-dot <%= pr.dotCls %>"></div>
          <div class="task-info" style="flex:1;min-width:0;">
            <div class="task-name"><%= t.task_name %></div>
            <div class="task-meta"><%= t.member_name %> · <%= t.project_name %></div>
            <div class="task-progress-wrap">
              <div class="task-progress-bar">
                <div class="task-progress-fill" style="width:<%= t.progress %>%"></div>
              </div>
              <input
                class="task-progress-input"
                type="number" min="0" max="100"
                value="<%= t.progress %>"
                data-id="<%= t.id %>"
              />
              <span class="task-progress-label">%</span>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;margin-left:10px;">
            <button class="btn-problem" data-id="<%= t.id %>" <%= t.status === 'problem' ? 'disabled' : '' %>>⚠ Problem</button>
            <button class="btn-complete" data-id="<%= t.id %>">✓ Complete</button>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </div>

  <!-- ── Team → Project Table (dynamic) ────────── -->
  <div class="db-card">
    <div class="db-card-hd">
      <h3>Projects by Team</h3>
      <span style="font-size:12px;color:var(--muted);"><%= teamProjects.length %> items</span>
    </div>
    <div class="db-card-body">
      <% if (!teamProjects || teamProjects.length === 0) { %>
        <div style="text-align:center;color:var(--muted);padding:30px 0;font-size:14px;">No data available</div>
      <% } else { %>
      <div class="db-table-wrap">
        <table class="db-table">
          <thead>
            <tr>
              <th>Team</th>
              <th>Project</th>
              <th>Sales</th>
              <th>Start Date</th>
              <th>End Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% teamProjects.forEach(function(tp) {
              const stMap = {
                in_progress: { cls:'st-in_progress', label:'In Progress' },
                delayed:     { cls:'st-delayed',     label:'Delayed'     },
                completed:   { cls:'st-completed',   label:'Completed'   },
              };
              const st = stMap[tp.status] || { cls:'', label: tp.status };
              function fmtDate(d) {
                if (!d) return '—';
                return new Date(d).toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric'});
              }
            %>
            <tr>
              <td><span class="team-chip"><%= tp.team_name %></span></td>
              <td><a href="/detail-project/<%= tp.project_id %>" style="font-weight:600;color:var(--text);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= tp.project_name || '—' %></a></td>
              <td><%= tp.sales_name || '—' %></td>
              <td><%= fmtDate(tp.start_date) %></td>
              <td><%= fmtDate(tp.end_date) %></td>
              <td><span class="st-badge <%= st.cls %>"><%= st.label %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

</section>

<!-- ── Modal กรอกรายละเอียด ──────────────────── -->
<div id="taskDetailModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:1000;align-items:center;justify-content:center;">
  <div style="background:#fff;border-radius:16px;padding:28px 28px 24px;width:100%;max-width:460px;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
    <h3 id="modalTitle" style="font-size:16px;font-weight:700;color:var(--text);margin-bottom:6px;"></h3>
    <p id="modalSubtitle" style="font-size:13px;color:var(--muted);margin-bottom:16px;"></p>
    <textarea id="modalDesc" rows="4" placeholder="Enter details..." style="width:100%;box-sizing:border-box;border:1px solid #cdd9e8;border-radius:10px;padding:10px 14px;font-size:14px;color:var(--text);outline:none;resize:vertical;font-family:inherit;"></textarea>
    <div style="display:flex;justify-content:flex-end;gap:8px;margin-top:16px;">
      <button id="modalCancel" style="padding:8px 20px;border-radius:8px;border:1px solid #ddd;background:#fff;font-size:13px;font-weight:600;cursor:pointer;color:var(--muted);">Cancel</button>
      <button id="modalConfirm" style="padding:8px 20px;border-radius:8px;border:none;font-size:13px;font-weight:700;cursor:pointer;color:#fff;background:#1d8f56;">Save</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast" style="position:fixed;bottom:24px;right:24px;background:#1e3a5f;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;font-weight:600;opacity:0;transition:opacity 0.3s;pointer-events:none;z-index:9999;"></div>

<script>
  const modal      = document.getElementById('taskDetailModal');
  const modalTitle = document.getElementById('modalTitle');
  const modalSub   = document.getElementById('modalSubtitle');
  const modalDesc  = document.getElementById('modalDesc');
  const modalOk    = document.getElementById('modalConfirm');
  const modalCancel = document.getElementById('modalCancel');

  let _pendingAction = null;

  function openModal(title, subtitle, confirmBg, action) {
    modalTitle.textContent    = title;
    modalSub.textContent      = subtitle;
    modalDesc.value           = '';
    modalOk.style.background  = confirmBg;
    modal.style.display       = 'flex';
    _pendingAction            = action;
    setTimeout(() => modalDesc.focus(), 100);
  }

  function closeModal() {
    modal.style.display = 'none';
    _pendingAction = null;
  }

  modalCancel.addEventListener('click', closeModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

  modalOk.addEventListener('click', async () => {
    if (!_pendingAction) return;
    const desc = modalDesc.value.trim();
    await _pendingAction(desc);
    closeModal();
  });

  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.opacity = '1';
    setTimeout(() => { t.style.opacity = '0'; }, 2500);
  }

  async function saveProgress(input) {
    let val = parseInt(input.value);
    if (isNaN(val)) val = 0;
    if (val < 0) val = 0;
    if (val > 100) val = 100;
    input.value = val;
    const fill = input.closest('.task-progress-wrap').querySelector('.task-progress-fill');
    fill.style.width = val + '%';
    await fetch('/dashboard-team/api/tasks/' + input.dataset.id + '/progress', {
      method: 'PATCH',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ progress: val }),
    });
    showToast('Progress updated: ' + val + '%');
  }

  document.addEventListener('change', (e) => {
    if (e.target.classList.contains('task-progress-input')) saveProgress(e.target);
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && e.target.classList.contains('task-progress-input')) {
      e.target.blur();
    }
  });

  document.addEventListener('click', (e) => {
    if (e.target.classList.contains('btn-complete')) {
      const btn = e.target;
      const taskName = btn.closest('.task-item')?.querySelector('.task-name')?.textContent || 'this task';
      openModal('✓ Mark Complete', `"${taskName}" — describe what was done`, '#1d8f56', async (desc) => {
        btn.disabled = true;
        btn.textContent = '...';
        await fetch('/dashboard-team/api/tasks/' + btn.dataset.id + '/complete', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ description: desc }),
        });
        showToast('Task completed ✓');
        setTimeout(() => location.reload(), 1000);
      });
    }

    if (e.target.classList.contains('btn-problem') && !e.target.disabled) {
      const btn = e.target;
      const taskName = btn.closest('.task-item')?.querySelector('.task-name')?.textContent || 'this task';
      openModal('⚠ Report Problem', `"${taskName}" — describe the issue`, '#e2a93b', async (desc) => {
        btn.disabled = true;
        btn.textContent = '...';
        await fetch('/dashboard-team/api/tasks/' + btn.dataset.id + '/problem', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ description: desc }),
        });
        showToast('Problem reported ⚠');
        setTimeout(() => location.reload(), 1000);
      });
    }
  });
</script>
