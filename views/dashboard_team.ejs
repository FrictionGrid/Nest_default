<style>
  /* ── Summary Cards ─────────────────────────────── */
  .db-stat-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 26px;
  }
  .db-stat {
    background: var(--card);
    border-radius: 16px;
    box-shadow: var(--shadow);
    padding: 20px 22px;
    border-top: 4px solid transparent;
    animation: fadeUp 0.4s ease both;
  }
  .db-stat h4 { font-size: 13px; color: var(--muted); margin-bottom: 8px; font-weight: 600; }
  .db-stat .val { font-size: 36px; font-weight: 800; color: var(--text); line-height: 1; }
  .db-stat p { font-size: 12px; color: var(--muted); margin-top: 6px; }
  .db-stat.s-just_started  { border-color: #4a90e2; }
  .db-stat.s-normal        { border-color: #1d8f56; }
  .db-stat.s-near_deadline { border-color: #e2a93b; }
  .db-stat.s-overdue       { border-color: #dc3545; }
  .db-stat.s-total         { border-color: #1e3a5f; }

  /* ── Two-col grid ──────────────────────────────── */
  .db-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }
  @media (max-width: 1100px) { .db-grid { grid-template-columns: 1fr; } }

  /* ── Card base ─────────────────────────────────── */
  .db-card {
    background: var(--card);
    border-radius: 18px;
    box-shadow: var(--shadow);
    overflow: hidden;
    animation: fadeUp 0.45s ease both;
  }
  .db-card-hd {
    padding: 18px 22px 14px;
    border-bottom: 1px solid #eef2f8;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .db-card-hd h3 { font-size: 15px; font-weight: 700; color: var(--text); }
  .db-card-body { padding: 16px 22px 20px; }

  /* ── Task list ─────────────────────────────────── */
  .task-list { display: flex; flex-direction: column; gap: 12px; }
  .task-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 14px 16px;
    border: 1px solid #eef2f8;
    border-radius: 12px;
    background: #fbfcfe;
    transition: border-color 0.2s;
  }
  .task-item:hover { border-color: #c5d8ef; }
  .task-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }
  .dot-in_progress { background: #4a90e2; }
  .dot-problem     { background: #e2a93b; }
  .dot-completed   { background: #1d8f56; }
  .task-info { flex: 1; min-width: 0; }
  .task-name { font-size: 14px; font-weight: 700; color: var(--text); }
  .task-meta { font-size: 12px; color: var(--muted); margin-top: 3px; }

  /* ── Task badges ───────────────────────────────── */
  .task-badge {
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px; white-space: nowrap;
  }
  /* Task status badges */
  .tb-in_progress { background: #e8f1fb; color: #2a5fa0; }
  .tb-problem     { background: rgba(226,169,59,0.13); color: #8a6400; }
  .tb-completed   { background: #dff5e7; color: #1a7a54; }
  /* Timeline badges */
  .tl-badge {
    font-size: 10px; font-weight: 700;
    padding: 2px 8px; border-radius: 999px; white-space: nowrap;
    margin-right: 4px;
  }
  .tl-just_started  { background: rgba(65,121,191,0.1); color: #2a5fa0; }
  .tl-has_time      { background: rgba(29,143,86,0.1);  color: #1a7a54; }
  .tl-near_deadline { background: rgba(226,169,59,0.13); color: #8a6400; }
  .tl-overdue       { background: rgba(220,53,69,0.1);  color: #b91c1c; }

  /* ── Complete button ───────────────────────────── */
  .btn-complete {
    font-size: 11px; font-weight: 700;
    padding: 4px 12px; border-radius: 999px;
    border: none; cursor: pointer;
    background: #1d8f56; color: #fff;
    transition: background 0.2s;
    white-space: nowrap;
  }
  .btn-complete:hover { background: #166040; }
  .btn-complete:disabled { background: #aaa; cursor: default; }

  /* ── Weekly Goal ───────────────────────────────── */
  .goal-wrap { padding: 4px 0; }
  .goal-meta {
    display: flex; justify-content: space-between;
    font-size: 13px; color: var(--muted); margin-bottom: 10px;
  }
  .goal-bar {
    width: 100%; height: 10px;
    background: #eef2f8; border-radius: 999px; overflow: hidden;
    margin-bottom: 20px;
  }
  .goal-fill {
    height: 100%;
    background: linear-gradient(90deg, #1e3a5f, #4a90e2);
    border-radius: 999px;
    transition: width 0.6s ease;
  }
  .mini-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .mini-card {
    padding: 14px 16px;
    border-radius: 12px;
    background: #f9fbfd;
    border: 1px solid #eef2f8;
  }
  .mini-card span { font-size: 12px; color: var(--muted); display: block; margin-bottom: 6px; }
  .mini-card strong { font-size: 22px; font-weight: 800; color: var(--text); }

  /* ── Project table ─────────────────────────────── */
  .db-table-wrap { overflow-x: auto; }
  .db-table { width: 100%; border-collapse: collapse; min-width: 600px; }
  .db-table thead th {
    text-align: left; padding: 12px 16px;
    background: #f4f7fb; color: var(--primary);
    font-size: 13px; font-weight: 700;
    border-bottom: 1px solid #e6edf5;
  }
  .db-table tbody td {
    padding: 14px 16px;
    font-size: 13px; color: #495565;
    border-bottom: 1px solid #f0f4fa;
  }
  .db-table tbody tr:hover { background: #f9fbfe; }
  .team-chip {
    display: inline-block;
    background: #e8f1fb; color: #2a5fa0;
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px;
  }
  .st-badge {
    display: inline-block;
    font-size: 11px; font-weight: 700;
    padding: 3px 10px; border-radius: 999px;
  }
  .st-in_progress { background: #e8f1fb; color: #2a5fa0; }
  .st-delayed     { background: #fde8e8; color: #b91c1c; }
  .st-completed   { background: #dff5e7; color: #1a7a54; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>

<section class="content">

  <!-- ── Summary Cards ─────────────────────────── -->
  <div class="db-stat-grid">
    <div class="db-stat s-just_started">
      <h4>Just Started</h4>
      <div class="val"><%= summary.just_started %></div>
      <p>0 – 20%</p>
    </div>
    <div class="db-stat s-normal">
      <h4>Normal</h4>
      <div class="val"><%= summary.normal %></div>
      <p>20 – 70%</p>
    </div>
    <div class="db-stat s-near_deadline">
      <h4>Near Deadline</h4>
      <div class="val"><%= summary.near_deadline %></div>
      <p>70 – 100%</p>
    </div>
    <div class="db-stat s-overdue">
      <h4>Overdue</h4>
      <div class="val"><%= summary.overdue %></div>
      <p>> 100%</p>
    </div>
  </div>

  <!-- ── Middle: Tasks + Goal ──────────────────── -->
  <div class="db-grid">

    <!-- Tasks (dynamic) -->
    <div class="db-card">
      <div class="db-card-hd">
        <h3>Task List</h3>
        <span style="font-size:12px;color:var(--muted);"><%= tasks.length %> items</span>
      </div>
      <div class="db-card-body">
        <% if (!tasks || tasks.length === 0) { %>
          <div style="text-align:center;color:var(--muted);padding:30px 0;font-size:14px;">No tasks found</div>
        <% } else { %>
        <div class="task-list">
          <% tasks.forEach(function(t) {
            const dotMap = { in_progress:'dot-in_progress', problem:'dot-problem', completed:'dot-completed' };
            const badgeMap = {
              in_progress: { cls:'tb-in_progress', label:'In Progress' },
              problem:     { cls:'tb-problem',     label:'Problem'     },
              completed:   { cls:'tb-completed',   label:'Completed'   },
            };
            const tlMap = {
              just_started:  { cls:'tl-just_started',  label:'Just Started'  },
              normal:        { cls:'tl-has_time',       label:'Normal'        },
              near_deadline: { cls:'tl-near_deadline',  label:'Near Deadline' },
              overdue:       { cls:'tl-overdue',        label:'Overdue'       },
            };
            const dot = dotMap[t.status] || 'dot-in_progress';
            const b   = badgeMap[t.status] || { cls:'', label: t.status };
            const tl  = tlMap[t.timeline]  || { cls:'', label: t.timeline };
          %>
          <div class="task-item">
            <div class="task-dot <%= dot %>"></div>
            <div class="task-info">
              <div class="task-name"><%= t.task_name %></div>
              <div class="task-meta"><%= t.member_name %> · <%= t.project_name %></div>
            </div>
            <div style="display:flex;align-items:center;gap:6px;flex-shrink:0;">
              <span class="tl-badge <%= tl.cls %>"><%= tl.label %></span>
              <span class="task-badge <%= b.cls %>"><%= b.label %></span>
              <% if (t.status !== 'completed') { %>
              <button class="btn-complete" data-id="<%= t.id %>">Done</button>
              <% } %>
            </div>
          </div>
          <% }); %>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Weekly Goal (dynamic) -->
    <%
      const totalTasks     = summary.total;
      const completedTasks = summary.completed;
      const goalPct = totalTasks > 0 ? Math.round((completedTasks / totalTasks) * 100) : 0;
    %>
    <div class="db-card">
      <div class="db-card-hd">
        <h3>Weekly Goal</h3>
        <strong style="color:var(--primary);font-size:15px;"><%= goalPct %>%</strong>
      </div>
      <div class="db-card-body">
        <div class="goal-wrap">
          <div class="goal-meta">
            <span>Overall Progress</span>
            <span><%= completedTasks %> / <%= totalTasks %> tasks</span>
          </div>
          <div class="goal-bar">
            <div class="goal-fill" style="width:<%= goalPct %>%"></div>
          </div>
          <div class="mini-grid">
            <div class="mini-card"><span>In Progress</span><strong><%= summary.pending %></strong></div>
            <div class="mini-card"><span>Problem</span><strong><%= summary.in_progress %></strong></div>
            <div class="mini-card"><span>Completed</span><strong><%= summary.completed %></strong></div>
            <div class="mini-card"><span>Total</span><strong><%= summary.total %></strong></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Team → Project Table (dynamic) ────────── -->
  <div class="db-card">
    <div class="db-card-hd">
      <h3>Projects by Team</h3>
      <span style="font-size:12px;color:var(--muted);"><%= teamProjects.length %> items</span>
    </div>
    <div class="db-card-body">
      <% if (!teamProjects || teamProjects.length === 0) { %>
        <div style="text-align:center;color:var(--muted);padding:30px 0;font-size:14px;">No data available</div>
      <% } else { %>
      <div class="db-table-wrap">
        <table class="db-table">
          <thead>
            <tr>
              <th>Team</th>
              <th>Project</th>
              <th>Sales</th>
              <th>Start Date</th>
              <th>End Date</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% teamProjects.forEach(function(tp) {
              const stMap = {
                in_progress: { cls:'st-in_progress', label:'In Progress' },
                delayed:     { cls:'st-delayed',     label:'Delayed'     },
                completed:   { cls:'st-completed',   label:'Completed'   },
              };
              const st = stMap[tp.status] || { cls:'', label: tp.status };
              function fmtDate(d) {
                if (!d) return '—';
                return new Date(d).toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric'});
              }
            %>
            <tr>
              <td><span class="team-chip"><%= tp.team_name %></span></td>
              <td><a href="/detail-project/<%= tp.project_id %>" style="font-weight:600;color:var(--text);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--text)'"><%= tp.project_name || '—' %></a></td>
              <td><%= tp.sales_name || '—' %></td>
              <td><%= fmtDate(tp.start_date) %></td>
              <td><%= fmtDate(tp.end_date) %></td>
              <td><span class="st-badge <%= st.cls %>"><%= st.label %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
      <% } %>
    </div>
  </div>

</section>

<!-- Toast -->
<div id="toast" style="position:fixed;bottom:24px;right:24px;background:#1e3a5f;color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;font-weight:600;opacity:0;transition:opacity 0.3s;pointer-events:none;z-index:9999;"></div>

<script>
  function showToast(msg) {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.style.opacity = '1';
    setTimeout(() => { t.style.opacity = '0'; }, 2500);
  }

  document.addEventListener('click', async (e) => {
    if (e.target.classList.contains('btn-complete')) {
      const id  = e.target.dataset.id;
      const btn = e.target;
      btn.disabled = true;
      btn.textContent = '...';
      await fetch('/dashboard-team/api/tasks/' + id + '/complete', { method: 'PUT' });
      showToast('Task marked as completed');
      setTimeout(() => location.reload(), 1000);
    }
  });
</script>
