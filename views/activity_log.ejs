const ACTION_LABEL = {
  login:'Login', logout:'Logout', create:'Create', update:'Update',
  delete:'Delete', view:'View', upload:'Upload', download:'Download', error:'Error',
};
const STATUS_ICON = { success:'●', failed:'✕', warning:'▲' };
const ROLE_LABEL  = {
  adminsystem:'Adminsystem', admin:'Admin', manager:'Manager',
  head_engineer:'Head Eng', engineer:'Engineer', sale:'Sale',
};

function renderRows(data) {
  const tbody = document.getElementById('logBody');
  tbody.innerHTML = data.map(r => `
    <tr data-action="${r.action}" data-status="${r.status}" data-module="${r.module}">
      <td>${r.id}</td>
      <td class="ts">${r.ts}</td>
      <td>
        <div style="font-weight:600;font-size:13px;">${r.name}</div>
        <div style="font-size:11px;color:var(--muted);">@${r.username}</div>
      </td>
      <td><span class="role-badge r-${r.role}">${ROLE_LABEL[r.role] || r.role}</span></td>
      <td><span class="action-badge a-${r.action}">${ACTION_LABEL[r.action] || r.action}</span></td>
      <td><span class="module-chip">${r.module}</span></td>
      <td class="desc-cell">${r.desc}</td>
      <td><span class="status-dot s-${r.status}">${STATUS_ICON[r.status]} ${r.status}</span></td>
    </tr>
  `).join('');
  document.getElementById('logCount').textContent = `Showing ${data.length} entries`;
}

function applyFilter() {
  const q      = document.getElementById('searchLog').value.toLowerCase();
  const action = document.getElementById('filterAction').value;
  const status = document.getElementById('filterStatus').value;
  const mod    = document.getElementById('filterModule').value;
  const result = LOGS.filter(r =>
    (!q      || r.username.toLowerCase().includes(q) || r.name.toLowerCase().includes(q) || r.desc.toLowerCase().includes(q)) &&
    (!action || r.action === action) &&
    (!status || r.status === status) &&
    (!mod    || r.module  === mod)
  );
  renderRows(result);
}

renderRows(LOGS);

document.getElementById('searchLog').addEventListener('input', applyFilter);
document.getElementById('filterAction').addEventListener('change', applyFilter);
document.getElementById('filterStatus').addEventListener('change', applyFilter);
document.getElementById('filterModule').addEventListener('change', applyFilter);
</script>
