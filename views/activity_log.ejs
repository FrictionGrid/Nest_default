  <div class="card1">
    <div class="table-header">
      <h3>Activity Log</h3>
      <div class="table-count" id="logCount">Showing 30 entries</div>
    </div>
    <div class="table-body">
      <table id="logTable">
        <colgroup>
          <col style="width:4%;"  />
          <col style="width:14%;" />
          <col style="width:15%;" />
          <col style="width:10%;" />
          <col style="width:11%;" />
          <col style="width:12%;" />
          <col style="width:26%;" />
          <col style="width:8%;"  />
        </colgroup>
        <thead>
          <tr>
            <th>#</th>
            <th>เวลา</th>
            <th>ผู้ใช้</th>
            <th>Role</th>
            <th>Action</th>
            <th>Module</th>
            <th>รายละเอียด</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="logBody">
        </tbody>
      </table>
    </div>
  </div>

</section>

