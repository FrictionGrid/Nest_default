<link rel="stylesheet" href="/css/tools/table.css" />
<style>
  .action-badge {
    display: inline-block; font-size: 11px; font-weight: 600;
    padding: 3px 10px; border-radius: 999px; white-space: nowrap;
    background: transparent; color: var(--text);
  }
  .status-dot {
    display: inline-flex; align-items: center; gap: 5px;
    font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 999px;
    background: transparent; color: var(--text);
  }
  .role-badge {
    display: inline-block; font-size: 10px; font-weight: 600;
    padding: 2px 8px; border-radius: 999px;
    background: transparent; color: var(--muted);
  }
  .ts { font-size: 12px; color: var(--muted); white-space: nowrap; }
  .desc-cell { font-size: 13px; max-width: 340px; }
  .module-chip {
    display: inline-block;
    font-size: 11px; font-weight: 600; padding: 2px 9px; border-radius: 8px;
    background: transparent; color: var(--muted); white-space: nowrap;
  }
</style>

<section class="content">

  <div class="toolbar">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M21 21L16.65 16.65M10.5 18C14.6421 18 18 14.6421 18 10.5C18 6.35786 14.6421 3 10.5 3C6.35786 3 3 6.35786 3 10.5C3 14.6421 6.35786 18 10.5 18Z"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <input type="text" id="searchLog" placeholder="ค้นหาผู้ใช้, คำอธิบาย..." />
    </div>
    <select id="filterAction" class="filter-box">
      <option value="">ทุก Action</option>
      <option value="login">Login</option>
      <option value="logout">Logout</option>
      <option value="create">Create</option>
      <option value="update">Update</option>
      <option value="delete">Delete</option>
      <option value="upload">Upload</option>
      <option value="download">Download</option>
    </select>
    <select id="filterStatus" class="filter-box">
      <option value="">ทุก Status</option>
      <option value="success">Success</option>
      <option value="failed">Failed</option>
      <option value="warning">Warning</option>
    </select>
    <select id="filterModule" class="filter-box">
      <option value="">ทุก Module</option>
      <option value="Auth">Auth</option>
      <option value="Incoming Project">Incoming Project</option>
      <option value="Manage Project">Manage Project</option>
      <option value="Manage Task">Manage Task</option>
      <option value="Dashboard Team">Dashboard Team</option>
      <option value="Detail Project">Detail Project</option>
      <option value="User Management">User Management</option>
      <option value="Payment">Payment</option>
      <option value="Timeline">Timeline</option>
    </select>
  </div>

  <div class="card1">
    <div class="table-header">
      <h3>Activity Log</h3>
      <div style="display:flex;align-items:center;gap:12px;">
        <div class="table-count" id="logCount">Loading...</div>
        <button class="btn-table btn-del" id="btnClearAll" onclick="confirmClearAll()">ลบทั้งหมด</button>
      </div>
    </div>
    <div class="table-body">
      <table id="logTable">
        <colgroup>
          <col style="width:4%;"  />
          <col style="width:13%;" />
          <col style="width:14%;" />
          <col style="width:9%;"  />
          <col style="width:9%;"  />
          <col style="width:11%;" />
          <col style="width:26%;" />
          <col style="width:7%;"  />
          <col style="width:7%;"  />
        </colgroup>
        <thead>
          <tr>
            <th>#</th>
            <th>เวลา</th>
            <th>ผู้ใช้</th>
            <th>Role</th>
            <th>Action</th>
            <th>Module</th>
            <th>รายละเอียด</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody id="logBody"></tbody>
      </table>
    </div>
  </div>

</section>

<script>
const ACTION_LABEL = {
  login:'Login', logout:'Logout', create:'Create', update:'Update',
  delete:'Delete', upload:'Upload', download:'Download',
};
const STATUS_ICON = { success:'●', failed:'✕', warning:'▲' };
const ROLE_LABEL  = {
  adminsystem:'Adminsystem', admin:'Admin', manager:'Manager',
  head_engineer:'Head Eng', engineer:'Engineer', sale:'Sale',
};

function formatTs(iso) {
  if (!iso) return '-';
  const d = new Date(iso);
  const pad = n => String(n).padStart(2,'0');
  return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())} ${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
}

function renderRows(items) {
  const tbody = document.getElementById('logBody');
  if (!items.length) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;color:var(--muted);padding:32px">ไม่มีข้อมูล</td></tr>';
    return;
  }
  tbody.innerHTML = items.map((r, i) => `
    <tr>
      <td>${i + 1}</td>
      <td class="ts">${formatTs(r.created_at)}</td>
      <td>
        <div style="font-weight:600;font-size:13px;">${r.user?.display_name ?? r.user?.username ?? '-'}</div>
        <div style="font-size:11px;color:var(--muted);">@${r.user?.username ?? '-'}</div>
      </td>
      <td><span class="role-badge">${ROLE_LABEL[r.user_role] ?? r.user_role ?? '-'}</span></td>
      <td><span class="action-badge a-${r.action}">${ACTION_LABEL[r.action] ?? r.action}</span></td>
      <td><span class="module-chip">${r.module}</span></td>
      <td class="desc-cell">${r.description ?? '-'}</td>
      <td><span class="status-dot s-${r.status}">${STATUS_ICON[r.status] ?? ''} ${r.status}</span></td>
      <td>
        <button class="btn-table btn-del" onclick="deleteLog(${r.id}, this)">ลบ</button>
      </td>
    </tr>
  `).join('');
  document.getElementById('logCount').textContent = `Showing ${items.length} entries`;
}

let debounceTimer;
function fetchLogs() {
  const params = new URLSearchParams();
  const search = document.getElementById('searchLog').value.trim();
  const action = document.getElementById('filterAction').value;
  const status = document.getElementById('filterStatus').value;
  const module = document.getElementById('filterModule').value;
  if (search) params.set('search', search);
  if (action) params.set('action', action);
  if (status) params.set('status', status);
  if (module) params.set('module', module);

  fetch(`/activity-log/api?${params}`)
    .then(r => r.json())
    .then(data => renderRows(data.items ?? []))
    .catch(() => renderRows([]));
}

function deleteLog(id, btn) {
  if (!confirm('ลบ log รายการนี้?')) return;
  btn.disabled = true;
  fetch(`/activity-log/api/${id}`, { method: 'DELETE' })
    .then(r => { if (r.ok) btn.closest('tr').remove(); else btn.disabled = false; })
    .catch(() => { btn.disabled = false; });
}

function confirmClearAll() {
  if (!confirm('ลบ log ทั้งหมด? ไม่สามารถกู้คืนได้')) return;
  fetch('/activity-log/api', { method: 'DELETE' })
    .then(r => { if (r.ok) { document.getElementById('logBody').innerHTML = ''; document.getElementById('logCount').textContent = 'Showing 0 entries'; }})
    .catch(() => {});
}

document.getElementById('searchLog').addEventListener('input', () => {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(fetchLogs, 300);
});
document.getElementById('filterAction').addEventListener('change', fetchLogs);
document.getElementById('filterStatus').addEventListener('change', fetchLogs);
document.getElementById('filterModule').addEventListener('change', fetchLogs);

fetchLogs();
</script>
