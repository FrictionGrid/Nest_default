<link rel="stylesheet" href="/css/tools/table.css" />
<style>
  /* ── Card ── */
  .pay-card {
    background: var(--card); border-radius: var(--radius);
    box-shadow: var(--shadow);
    border: 1.5px solid var(--border);
    border-left: 5px solid #d1dce8;
    padding: 18px 22px 18px 20px;
    margin-bottom: 12px; cursor: pointer;
    transition: transform .2s, box-shadow .2s, border-color .2s;
    animation: fadeUp .3s ease both;
    text-decoration: none; display: block;
  }
  .pay-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 28px rgba(30,58,95,.13);
    border-color: rgba(74,144,226,.4);
    border-left-color: inherit;
  }
  .pay-card.s-in_progress { border-left-color: #4A90E2; }
  .pay-card.s-completed   { border-left-color: #35B37E; }
  .pay-card.s-delayed     { border-left-color: #E45757; }

  /* ── Card top row ── */
  .pay-card-top {
    display: flex; align-items: center;
    justify-content: space-between; gap: 14px;
  }
  .pay-card-meta { flex: 1; min-width: 0; }
  .pay-project-name {
    font-size: 15px; font-weight: 700; color: var(--primary);
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    margin-bottom: 3px;
  }
  .pay-po-no { font-size: 12px; color: var(--muted); }
  .pay-card-right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .pay-po-val { font-size: 14px; font-weight: 800; color: #1E3A5F; white-space: nowrap; }

  .sb {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 999px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
  }
  .sb::before { content:''; width:5px; height:5px; border-radius:50%; background:currentColor; }
  .sb-in_progress { background:rgba(74,144,226,.13); color:#1d5fa8; }
  .sb-completed   { background:rgba(53,179,126,.13); color:#1a7a54; }
  .sb-delayed     { background:rgba(228,87,87,.13);  color:#b91c1c; }

  /* ── Divider ── */
  .pay-sep { height:1px; background:var(--border); margin:14px 0; }

  /* ── Progress row ── */
  .pay-prog-row {
    display: flex; align-items: center; gap: 14px;
  }
  .prog-label {
    font-size: 12px; color: var(--muted);
    white-space: nowrap; flex-shrink: 0; min-width: 160px;
  }
  .prog-label strong { color: var(--primary); font-weight: 700; }
  .prog-track {
    flex: 1; height: 8px; background: #e6edf6;
    border-radius: 999px; overflow: hidden; min-width: 60px;
  }
  .prog-fill { height:100%; border-radius:999px; transition:width 1s ease .25s; }
  .prog-pct { font-size:13px; font-weight:800; color:var(--primary); white-space:nowrap; min-width:38px; text-align:right; }
  .no-po-msg { font-size:12px; color:var(--muted); font-style:italic; padding:6px 0; }

  /* ── Timeline ── */
  .tl-wrap { overflow-x:auto; padding-bottom:2px; }
  .tl-track { display:flex; align-items:flex-start; min-width:max-content; }
  .tl-node  { display:flex; flex-direction:column; align-items:center; min-width:80px; }

  .tl-circle {
    width:20px; height:20px; border-radius:50%;
    border:2.5px solid; flex-shrink:0;
    display:flex; align-items:center; justify-content:center;
  }
  .tl-c-paid    { background:#35B37E; border-color:#35B37E; box-shadow:0 0 0 4px rgba(53,179,126,.18); }
  .tl-c-pending { background:#F4A62A; border-color:#F4A62A; box-shadow:0 0 0 4px rgba(244,166,42,.18); }
  .tl-c-upcoming { background:var(--card); border-color:#CBD5E1; }

  .tl-line { flex:1; height:2px; min-width:40px; background:#e2e8f0; margin-top:9px; flex-shrink:0; }
  .tl-line-paid { background:#35B37E; }
  .tl-line-pending { background:#F4A62A; }

  .tl-info { margin-top:6px; text-align:center; }
  .tl-date { font-size:10px; color:var(--muted); white-space:nowrap; }
  .tl-amt  { font-size:11px; font-weight:700; color:var(--primary); white-space:nowrap; margin-top:2px; }
  .tl-status-dot { font-size:9px; font-weight:700; margin-top:1px; white-space:nowrap; }
  .tl-dot-paid    { color:#1a7a54; }
  .tl-dot-pending { color:#9a6000; }
  .tl-dot-upcoming{ color:#94A3B8; }

  /* No installments */
  .no-inst-state {
    display:flex; align-items:center; gap:8px;
    padding:10px 0; color:var(--muted); font-size:12px; font-style:italic;
  }

  /* ── Skeleton ── */
  .pay-skeleton {
    height:150px; border-radius:var(--radius);
    background:linear-gradient(90deg,#f0f4f8 25%,#e4ebf3 50%,#f0f4f8 75%);
    background-size:200% 100%; animation:shimmer 1.4s infinite;
    margin-bottom:12px; border-left:5px solid #d1dce8;
  }
  @keyframes shimmer { 0%{background-position:-200% 0} 100%{background-position:200% 0} }

  /* ── Empty ── */
  .pay-empty { text-align:center; padding:60px 20px; color:var(--muted); }
  .pay-empty-icon  { font-size:44px; margin-bottom:12px; }
  .pay-empty-title { font-size:15px; font-weight:700; color:var(--primary); }
  .pay-empty-sub   { font-size:13px; margin-top:4px; }

  @keyframes fadeUp {
    from { opacity:0; transform:translateY(14px); }
    to   { opacity:1; transform:translateY(0); }
  }
</style>

<section class="content">

  <div class="toolbar">
    <div class="search-box">
      <svg viewBox="0 0 24 24" fill="none">
        <path d="M21 21L16.65 16.65M10.5 18C14.6421 18 18 14.6421 18 10.5C18 6.35786 14.6421 3 10.5 3C6.35786 3 3 6.35786 3 10.5C3 14.6421 6.35786 18 10.5 18Z"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
      <input type="text" id="searchInput" placeholder="Search Project Name, PO No..." />
    </div>
    <select id="filterYear" class="filter-box">
      <option value="">All Years</option>
    </select>
    <select id="filterMonth" class="filter-box">
      <option value="">All Months</option>
      <option value="1">January</option>
      <option value="2">February</option>
      <option value="3">March</option>
      <option value="4">April</option>
      <option value="5">May</option>
      <option value="6">June</option>
      <option value="7">July</option>
      <option value="8">August</option>
      <option value="9">September</option>
      <option value="10">October</option>
      <option value="11">November</option>
      <option value="12">December</option>
    </select>
    <select id="filterSale" class="filter-box">
      <option value="">All Sales</option>
    </select>
    <select id="statusFilter" class="filter-box">
      <option value="">All Status</option>
      <option value="in_progress">In Progress</option>
      <option value="completed">Completed</option>
      <option value="delayed">Delayed</option>
    </select>
  </div>

  <div id="projectList">
    <div class="pay-skeleton"></div>
    <div class="pay-skeleton" style="opacity:.7;animation-delay:.08s;"></div>
    <div class="pay-skeleton" style="opacity:.5;animation-delay:.16s;"></div>
  </div>

</section>

<script>
  const SL = { in_progress:'In Progress', completed:'Completed', delayed:'Delayed' };

  const fmt     = n => Number(n||0).toLocaleString('th-TH',{maximumFractionDigits:0});
  const fmtShort = n => {
    const v = Number(n||0);
    if (v >= 1000000) return (v/1000000).toFixed(2).replace(/\.?0+$/,'') + 'M';
    if (v >= 1000)    return (v/1000).toFixed(0) + 'K';
    return v.toLocaleString();
  };
  const fmtDate = d => {
    if (!d) return '—';
    return new Date(d).toLocaleDateString('en-GB',{day:'2-digit',month:'short'});
  };
  const esc = s => String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  const ICON_CHECK = `<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>`;
  const ICON_WARN  = `<svg width="9"  height="9"  viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`;

  function renderProgress(p) {
    if (!p.po_value) return `<div class="no-po-msg">ยังไม่มีมูลค่า PO</div>`;
    const total = p.installments.length;
    const paid  = p.installments.filter(i => i.status === 'paid').length;
    const pct   = Math.min(100, Math.round((p.paidAmount / p.po_value) * 100));
    const color = pct >= 80 ? '#35B37E' : pct >= 40 ? '#4A90E2' : '#94A3B8';
    return `
      <div class="pay-prog-row">
        <div class="prog-label">
          ${total ? `${paid}/${total} งวด &nbsp;•&nbsp; จ่ายแล้ว <strong>฿${fmtShort(p.paidAmount)}</strong>` : 'ยังไม่มีงวด'}
        </div>
        <div class="prog-track">
          <div class="prog-fill" style="width:${pct}%;background:${color};"></div>
        </div>
        <div class="prog-pct">${pct}%</div>
      </div>`;
  }

  function renderTimeline(insts) {
    if (!insts || !insts.length) return `
      <div class="no-inst-state">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        ยังไม่มีแผนการชำระ — คลิกเพื่อเพิ่ม
      </div>`;

    const MAX   = 7;
    const items = insts.slice(0, MAX);
    const extra = insts.length - MAX;

    let html = `<div class="tl-wrap"><div class="tl-track">`;
    items.forEach((inst, idx) => {
      const isLast = idx === items.length - 1 && extra <= 0;
      const icon   = inst.status === 'paid' ? ICON_CHECK : inst.status === 'pending' ? ICON_WARN : '';
      const dotLbl = inst.status === 'paid' ? 'Paid' : inst.status === 'pending' ? 'Pending' : 'Upcoming';
      html += `
        <div class="tl-node">
          <div class="tl-circle tl-c-${inst.status}">${icon}</div>
          <div class="tl-info">
            <div class="tl-date">${fmtDate(inst.due_date)}</div>
            <div class="tl-amt">฿${fmtShort(inst.amount)}</div>
            <div class="tl-status-dot tl-dot-${inst.status}">${dotLbl}</div>
          </div>
        </div>`;
      if (!isLast) {
        const lineClass = inst.status === 'paid' ? ' tl-line-paid' : inst.status === 'pending' ? ' tl-line-pending' : '';
        html += `<div class="tl-line${lineClass}"></div>`;
      }
    });
    if (extra > 0) {
      html += `<div class="tl-line"></div>
        <div class="tl-node">
          <div class="tl-circle tl-c-upcoming" style="font-size:8px;font-weight:800;color:#94A3B8;">+${extra}</div>
          <div class="tl-info"><div class="tl-date">more</div></div>
        </div>`;
    }
    return html + `</div></div>`;
  }

  function renderCards(projects) {
    const list = document.getElementById('projectList');
    if (!projects.length) {
      list.innerHTML = `<div class="pay-empty">
        <div class="pay-empty-icon">📋</div>
        <div class="pay-empty-title">ไม่พบโครงการ</div>
        <div class="pay-empty-sub">ลองเปลี่ยนคำค้นหาหรือตัวกรอง</div>
      </div>`;
      return;
    }
    list.innerHTML = projects.map((p, i) => `
      <a class="pay-card s-${p.status}" href="/detail-payment/${p.id}" style="animation-delay:${i*.05}s;">
        <div class="pay-card-top">
          <div class="pay-card-meta">
            <div class="pay-project-name">${esc(p.project_name)}</div>
            <div class="pay-po-no">${p.po_no ? 'PO: '+esc(p.po_no) : 'ไม่มีเลข PO'}</div>
          </div>
          <div class="pay-card-right">
            <span class="pay-po-val">${p.po_value ? '฿'+fmt(p.po_value) : '—'}</span>
            <span class="sb sb-${p.status}">${SL[p.status]||p.status}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2.5">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </div>
        </div>
        <div class="pay-sep"></div>
        ${renderProgress(p)}
        <div class="pay-sep"></div>
        ${renderTimeline(p.installments)}
      </a>`).join('');
  }

  let searchTimer;
  let allProjects = [];

  function populateYears(projects) {
    const years = [...new Set(
      projects.filter(p => p.created_at)
              .map(p => new Date(p.created_at).getFullYear())
    )].sort((a, b) => b - a);

    const sel = document.getElementById('filterYear');
    sel.innerHTML = '<option value="">All Years</option>';
    years.forEach(y => {
      const opt = document.createElement('option');
      opt.value = y; opt.textContent = y;
      sel.appendChild(opt);
    });
  }

  function populateSales(projects) {
    const names = [...new Set(
      projects.map(p => p.sales_name).filter(Boolean)
    )].sort((a, b) => a.localeCompare(b, 'th'));

    const sel = document.getElementById('filterSale');
    sel.innerHTML = '<option value="">All Sales</option>';
    names.forEach(n => {
      const opt = document.createElement('option');
      opt.value = n; opt.textContent = n;
      sel.appendChild(opt);
    });
  }

  async function load(isFirstLoad = false) {
    const search = document.getElementById('searchInput').value.trim();
    const status = document.getElementById('statusFilter').value;
    const year   = document.getElementById('filterYear').value;
    const month  = document.getElementById('filterMonth').value;
    const sale   = document.getElementById('filterSale').value;
    try {
      const params = new URLSearchParams();
      if (search) params.set('search', search);
      if (status) params.set('status', status);
      if (year)   params.set('year',   year);
      if (month)  params.set('month',  month);
      if (sale)   params.set('sale',   sale);
      const res = await fetch(`/payment/api/projects?${params}`);
      const projects = await res.json();
      if (isFirstLoad) {
        allProjects = projects;
        populateYears(projects);
        populateSales(projects);
      }
      renderCards(projects);
    } catch {
      document.getElementById('projectList').innerHTML =
        `<div class="pay-empty"><div class="pay-empty-icon">⚠️</div><div class="pay-empty-title">โหลดข้อมูลไม่สำเร็จ</div></div>`;
    }
  }

  document.getElementById('searchInput').addEventListener('input', () => {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(() => load(), 320);
  });
  document.getElementById('filterYear').addEventListener('change',   () => load());
  document.getElementById('filterMonth').addEventListener('change',  () => load());
  document.getElementById('filterSale').addEventListener('change',   () => load());
  document.getElementById('statusFilter').addEventListener('change', () => load());

  load(true);
</script>
