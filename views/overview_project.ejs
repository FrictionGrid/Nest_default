<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  a    { text-decoration: none; color: inherit; }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-bottom: 24px;
  }
  .stat-card {
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 22px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    transition: all 0.22s ease;
    position: relative;
    overflow: hidden;
    animation: fadeUp 0.45s ease both;
  }
  .stat-card:nth-child(1) { animation-delay: 0.05s; }
  .stat-card:nth-child(2) { animation-delay: 0.10s; }
  .stat-card:nth-child(3) { animation-delay: 0.15s; }
  .stat-card:nth-child(4) { animation-delay: 0.20s; }
  .stat-card:hover { box-shadow: 0 8px 28px rgba(30,58,95,0.13); transform: translateY(-4px); }

  .stat-icon {
    width: 52px; height: 52px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .si-blue   { background: rgba(74,144,226,0.14); color: #4A90E2; }
  .si-green  { background: rgba(53,179,126,0.14); color: #35B37E; }
  .si-orange { background: rgba(244,166,42,0.14);  color: #F4A62A; }
  .si-purple { background: rgba(155,89,182,0.14);  color: #9B59B6; }

  .stat-body  { flex: 1; min-width: 0; }
  .stat-label { font-size: 12px; color: var(--muted); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .stat-value { font-size: 30px; font-weight: 800; color: var(--primary); line-height: 1.1; margin-bottom: 5px; }
  .stat-from  { font-size: 11px; color: #8faac4; margin-top: 2px; }

  .grid-2 {
    display: grid;
    grid-template-columns: 1.35fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  .card {
    background: var(--card);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    animation: fadeUp 0.45s ease both;
    animation-delay: 0.28s;
  }
  .card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 22px 16px;
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap; gap: 10px;
  }
  .card-title { font-size: 15px; font-weight: 700; color: var(--primary); }
  .card-body  { padding: 20px 22px; }
  .card-sub   { font-size: 12px; color: var(--muted); }

  .chart-filters { display: flex; gap: 5px; flex-wrap: wrap; }
  .filter-btn {
    padding: 5px 13px; border-radius: 999px; font-size: 12px; font-weight: 600;
    border: 1px solid var(--border); background: transparent; color: var(--muted);
    transition: all 0.22s ease; cursor: pointer;
  }
  .filter-btn:hover  { border-color: #4A90E2; color: #4A90E2; }
  .filter-btn.active { background: var(--primary); border-color: var(--primary); color: #fff; }

  .chart-wrap { position: relative; height: 260px; }
  .chart-legend { display: flex; gap: 16px; margin-top: 14px; flex-wrap: wrap; }
  .legend-item  { display: flex; align-items: center; gap: 7px; font-size: 12px; color: var(--muted); }
  .ld-bar { width: 12px; height: 12px; border-radius: 3px; flex-shrink: 0; }

  .country-list { display: flex; flex-direction: column; gap: 20px; }
  .country-item { display: flex; flex-direction: column; gap: 5px; }
  .country-row  { display: flex; align-items: center; justify-content: space-between; font-size: 13px; }
  .country-name  { display: flex; align-items: center; gap: 8px; font-weight: 500; }
  .country-value { font-weight: 700; color: var(--primary); font-size: 13px; }
  .prog-bar  { width: 100%; height: 6px; background: #e6edf6; border-radius: 999px; overflow: hidden; }
  .prog-fill { height: 100%; border-radius: 999px; width: 0%; transition: width 1s ease 0.4s; }

  .table-wrap { overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; min-width: 360px; }
  thead th {
    text-align: left; padding: 11px 16px;
    background: #eef4fb; color: #2a4a70;
    font-size: 11px; font-weight: 700;
    border-bottom: 2px solid #ccdaec;
    letter-spacing: 0.5px; text-transform: uppercase; white-space: nowrap;
  }
  tbody tr { border-bottom: 1px solid #edf2f7; transition: all 0.22s ease; }
  tbody tr:last-child { border-bottom: none; }
  tbody tr:hover { background: #f3f8fd; }
  tbody td { padding: 13px 16px; font-size: 13px; color: #2e4a6a; vertical-align: middle; }

  .order-sub { font-size: 11px; color: #7a99b8; margin-top: 2px; }

  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 999px;
    font-size: 11px; font-weight: 600; white-space: nowrap;
  }
  .badge::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
  .b-completed  { background: rgba(53,179,126,0.13); color: #1a7a54; }
  .b-processing { background: rgba(74,144,226,0.14); color: #1d5fa8; }
  .b-blocked    { background: rgba(228,87,87,0.12);  color: #c0392b; }
  .b-pending    { background: rgba(244,166,42,0.14); color: #9a6000; }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1200px) {
    .stats-grid { grid-template-columns: repeat(2,1fr); }
    .grid-2     { grid-template-columns: 1fr; }
  }
  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: repeat(2,1fr); gap: 12px; }
    .stat-value { font-size: 22px; }
    .card-body  { padding: 14px 16px; }
  }
  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: 1fr; }
  }
</style>

<section class="content">

  <!-- ===== Stats Cards ===== -->
  <div class="stats-grid">

    <div class="stat-card">
      <div class="stat-icon si-green">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="1" x2="12" y2="23"/>
          <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Value</div>
        <div class="stat-value">฿<%= (Number(summary.total_revenue) / 1000000).toFixed(1) %>M</div>
        <div class="stat-from">Total project value</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-blue">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Total Projects</div>
        <div class="stat-value"><%= summary.total_projects %></div>
        <div class="stat-from">All projects</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-purple">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Completed</div>
        <div class="stat-value"><%= summary.completed %></div>
        <div class="stat-from">Projects done</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-orange">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/>
          <line x1="12" y1="8" x2="12" y2="12"/>
          <line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Delayed</div>
        <div class="stat-value"><%= summary.delayed %></div>
        <div class="stat-from">Behind schedule</div>
      </div>
    </div>

  </div>

  <!-- ===== Middle Row ===== -->
  <div class="grid-2">

    <div class="card">
      <div class="card-header">
        <span class="card-title">Projects by Team</span>
        <div class="chart-filters" id="teamRangeFilters">
          <button class="filter-btn active" data-range="all">ALL</button>
          <button class="filter-btn" data-range="1m">1M</button>
          <button class="filter-btn" data-range="3m">3M</button>
          <button class="filter-btn" data-range="6m">6M</button>
          <button class="filter-btn" data-range="12m">12M</button>
        </div>
      </div>
      <div class="card-body">
        <div class="chart-wrap">
          <canvas id="teamProjectChart"></canvas>
        </div>
        <div class="chart-legend">
          <div class="legend-item"><div class="ld-bar" style="background:#8E9FB2;"></div>Total</div>
          <div class="legend-item"><div class="ld-bar" style="background:#4A90E2;"></div>In Progress</div>
          <div class="legend-item"><div class="ld-bar" style="background:#35B37E;"></div>Completed</div>
          <div class="legend-item"><div class="ld-bar" style="background:#E45757;"></div>Delayed</div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <span class="card-title">Projects by Region</span>
        <span class="card-sub">4 regions</span>
      </div>
      <div class="card-body">
        <% const regionColors = ['#4A90E2','#35B37E','#F4A62A','#9B59B6']; %>
        <% const regionColorPairs = [['#4A90E2','#6baef5'],['#35B37E','#5fd4a1'],['#F4A62A','#f7c060'],['#9B59B6','#c090d8']]; %>
        <% const maxRegion = regionStats.reduce((m, r) => Math.max(m, r.total), 1); %>
        <div class="country-list">
          <% regionStats.forEach(function(r, i) {
            const pct = Math.round((r.total / maxRegion) * 100);
          %>
          <div class="country-item">
            <div class="country-row">
              <div class="country-name">
                <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:<%= regionColors[i] %>;flex-shrink:0;"></span>
                <%= r.label %>
              </div>
              <div class="country-value"><%= r.total %> projects</div>
            </div>
            <div class="prog-bar">
              <div class="prog-fill" data-w="<%= pct %>" style="background:linear-gradient(90deg,<%= regionColorPairs[i][0] %>,<%= regionColorPairs[i][1] %>);"></div>
            </div>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

  </div>

  <!-- ===== Bottom Row ===== -->
  <div class="grid-2">

    <div class="card">
      <div class="card-header">
        <span class="card-title">New Projects</span>
        <span class="card-sub">Latest 7 entries</span>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Date</th>
              <th>Project Name</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (!recentProjects || recentProjects.length === 0) { %>
            <tr><td colspan="3" style="text-align:center;color:var(--muted);padding:24px;">No data available</td></tr>
            <% } else { %>
            <% recentProjects.forEach(function(p) {
              const badgeMap = {
                completed:   { cls: 'b-completed',  label: 'Completed'   },
                in_progress: { cls: 'b-processing', label: 'In Progress' },
                delayed:     { cls: 'b-blocked',    label: 'Delayed'     },
              };
              const b = badgeMap[p.status] || { cls: 'b-pending', label: p.status };
              const dateStr = p.date_in ? new Date(p.date_in).toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'}) : '—';
            %>
            <tr>
              <td><%= dateStr %></td>
              <td>
                <a href="/detail-project/<%= p.id %>" style="font-weight:600;color:var(--primary);text-decoration:none;" onmouseover="this.style.color='var(--accent)'" onmouseout="this.style.color='var(--primary)'"><%= p.project_name || '—' %></a>
                <div class="order-sub"><%= p.sales_name || '' %></div>
              </td>
              <td><span class="badge <%= b.cls %>"><%= b.label %></span></td>
            </tr>
            <% }); %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <span class="card-title">Yearly Project Summary</span>
        <span class="card-sub">Year <%= new Date().getFullYear() %></span>
      </div>
      <div class="table-wrap">
        <table style="table-layout:fixed;width:100%;">
          <colgroup>
            <col style="width:28%;"><col style="width:18%;"><col style="width:18%;"><col style="width:18%;"><col style="width:18%;">
          </colgroup>
          <thead>
            <tr>
              <th>Month</th>
              <th style="text-align:center;">Total</th>
              <th style="text-align:center;color:#4A90E2;">In Progress</th>
              <th style="text-align:center;color:#1a7a54;">Completed</th>
              <th style="text-align:center;color:#c0392b;">Delayed</th>
            </tr>
          </thead>
          <tbody>
            <% monthlySummary.forEach(function(m) { %>
            <tr>
              <td><%= m.month_name %></td>
              <td style="text-align:center;"><%= m.total_projects !== null ? m.total_projects : '—' %></td>
              <td style="text-align:center;color:#4A90E2;font-weight:600;"><%= m.in_progress !== null ? m.in_progress : '—' %></td>
              <td style="text-align:center;color:#1a7a54;font-weight:600;"><%= m.completed !== null ? m.completed : '—' %></td>
              <td style="text-align:center;color:#c0392b;font-weight:600;"><%= m.delayed !== null ? m.delayed : '—' %></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>

  </div>

</section>

<script>
  const _teams = <%- JSON.stringify(teams) %>;
  const teamCtx = document.getElementById("teamProjectChart").getContext("2d");

  const teamChart = new Chart(teamCtx, {
    type: "bar",
    data: {
      labels: _teams.map(t => t.team_name),
      datasets: [
        { label: "Total",       data: _teams.map(t => Number(t.total_projects)), backgroundColor: "rgba(142,159,178,0.22)", borderColor: "#8E9FB2", borderWidth: 1.5, borderRadius: 5 },
        { label: "In Progress", data: _teams.map(t => Number(t.in_progress)),    backgroundColor: "rgba(74,144,226,0.22)",  borderColor: "#4A90E2", borderWidth: 1.5, borderRadius: 5 },
        { label: "Completed",   data: _teams.map(t => Number(t.completed)),      backgroundColor: "rgba(53,179,126,0.22)",  borderColor: "#35B37E", borderWidth: 1.5, borderRadius: 5 },
        { label: "Delayed",     data: _teams.map(t => Number(t.delayed)),        backgroundColor: "rgba(228,87,87,0.18)",   borderColor: "#E45757", borderWidth: 1.5, borderRadius: 5 }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: "index", intersect: false },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: "#1E3A5F", titleColor: "#fff", bodyColor: "rgba(255,255,255,0.78)",
          padding: 12, cornerRadius: 10, boxPadding: 5,
          callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y} projects` }
        }
      },
      scales: {
        x: { grid: { color: "rgba(217,226,236,0.5)" }, ticks: { color: "#56718f", font: { size: 12 } } },
        y: { beginAtZero: true, grid: { color: "rgba(217,226,236,0.5)" }, ticks: { color: "#56718f", font: { size: 11 }, stepSize: 2, callback: v => v + " projects" } }
      }
    }
  });

  function animateProgressBars() {
    document.querySelectorAll(".prog-fill").forEach(el => {
      const target = el.dataset.w + "%";
      el.style.width = "0%";
      requestAnimationFrame(() => { setTimeout(() => { el.style.width = target; }, 100); });
    });
  }
  window.addEventListener("load", animateProgressBars);

  const teamColors     = ['#4A90E2','#35B37E','#F4A62A','#9B59B6','#E45757'];
  const teamColorPairs = [['#4A90E2','#6baef5'],['#35B37E','#5fd4a1'],['#F4A62A','#f7c060'],['#9B59B6','#c090d8'],['#E45757','#f08080']];

  document.querySelectorAll("#teamRangeFilters .filter-btn").forEach(btn => {
    btn.addEventListener("click", async () => {
      document.querySelectorAll("#teamRangeFilters .filter-btn").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      const range = btn.dataset.range;
      const res   = await fetch(`/overview-project/api/team-stats?range=${range}`);
      const data  = await res.json();
      teamChart.data.labels           = data.map(t => t.team_name);
      teamChart.data.datasets[0].data = data.map(t => Number(t.total_projects));
      teamChart.data.datasets[1].data = data.map(t => Number(t.in_progress));
      teamChart.data.datasets[2].data = data.map(t => Number(t.completed));
      teamChart.data.datasets[3].data = data.map(t => Number(t.delayed));
      teamChart.update();
      const maxProj = data.reduce((m, t) => Math.max(m, Number(t.total_projects)), 1);
      const listEl  = document.querySelector(".country-list");
      listEl.innerHTML = data.map((t, i) => {
        const ci  = i % teamColors.length;
        const pct = Math.round((Number(t.total_projects) / maxProj) * 100);
        return `<div class="country-item">
          <div class="country-row">
            <div class="country-name">
              <span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${teamColors[ci]};flex-shrink:0;"></span>
              ${t.team_name}
            </div>
            <div class="country-value">${t.total_projects} projects</div>
          </div>
          <div class="prog-bar">
            <div class="prog-fill" data-w="${pct}" style="background:linear-gradient(90deg,${teamColorPairs[ci][0]},${teamColorPairs[ci][1]});width:0%"></div>
          </div>
        </div>`;
      }).join('');
      animateProgressBars();
    });
  });
</script>
