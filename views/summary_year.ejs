<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  /* ── helpers ── */
  .fmt-m { font-size: 11px; color: var(--muted); }

  /* ── year hero banner ── */
  .year-hero {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, #1E3A5F 0%, #2d5a9e 55%, #4A90E2 100%);
    border-radius: var(--radius);
    box-shadow: 0 8px 32px rgba(30,58,95,0.22);
    padding: 28px 32px;
    margin-bottom: 24px;
    display: flex; align-items: center; justify-content: space-between; gap: 20px;
    flex-wrap: wrap;
    animation: fadeUp 0.4s ease both;
  }
  /* decorative circles */
  .year-hero::before, .year-hero::after {
    content: ''; position: absolute; border-radius: 50%; opacity: 0.08;
    background: #fff; pointer-events: none;
  }
  .year-hero::before { width: 260px; height: 260px; top: -80px; right: -60px; }
  .year-hero::after  { width: 160px; height: 160px; bottom: -50px; left: 180px; }

  .year-hero-left { display: flex; flex-direction: column; gap: 4px; position: relative; z-index: 1; }
  .year-hero-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 2px;
    text-transform: uppercase; color: rgba(255,255,255,0.6);
  }
  .year-hero-title {
    font-size: 28px; font-weight: 900; color: #fff; line-height: 1.1;
    display: flex; align-items: center; gap: 10px;
  }
  .year-hero-title svg { opacity: .7; flex-shrink: 0; }
  .year-hero-sub { font-size: 13px; color: rgba(255,255,255,0.65); margin-top: 2px; }

  .year-hero-right { position: relative; z-index: 1; }
  .year-selector-wrap { display: flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.12); border: 1.5px solid rgba(255,255,255,0.25);
    border-radius: 12px; padding: 10px 16px; backdrop-filter: blur(6px); }
  .year-selector-wrap label { font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.75);
    text-transform: uppercase; letter-spacing: 1px; white-space: nowrap; }
  .year-select { background: transparent; border: none; outline: none;
    font-size: 20px; font-weight: 900; color: #fff; cursor: pointer;
    appearance: none; -webkit-appearance: none; min-width: 70px; }
  .year-select option { background: #1E3A5F; color: #fff; font-weight: 700; }

  /* ── stat cards ── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-bottom: 24px;
  }
  @media (max-width: 1100px) { .stats-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 600px)  { .stats-grid { grid-template-columns: 1fr; } }

  .stat-card {
    background: var(--card); border-radius: var(--radius);
    box-shadow: var(--shadow); padding: 20px 18px;
    display: flex; align-items: center; gap: 14px;
    transition: transform 0.2s, box-shadow 0.2s;
    animation: fadeUp 0.4s ease both;
  }
  .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(30,58,95,0.12); }
  .stat-card:nth-child(1){ animation-delay:.05s } .stat-card:nth-child(2){ animation-delay:.09s }
  .stat-card:nth-child(3){ animation-delay:.13s } .stat-card:nth-child(4){ animation-delay:.17s }
  .stat-card:nth-child(5){ animation-delay:.21s } .stat-card:nth-child(6){ animation-delay:.25s }

  .stat-icon { width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
  .si-blue   { background:rgba(74,144,226,0.14); color:#4A90E2; }
  .si-green  { background:rgba(53,179,126,0.14); color:#35B37E; }
  .si-orange { background:rgba(244,166,42,0.14); color:#F4A62A; }
  .si-purple { background:rgba(155,89,182,0.14); color:#9B59B6; }
  .si-red    { background:rgba(228,87,87,0.14);  color:#E45757; }
  .si-teal   { background:rgba(20,184,166,0.14); color:#14B8A6; }

  .stat-body { flex:1; min-width:0; }
  .stat-label { font-size:11px; color:var(--muted); text-transform:uppercase; letter-spacing:.5px; margin-bottom:3px; }
  .stat-value { font-size:26px; font-weight:800; color:var(--primary); line-height:1.1; }
  .stat-sub   { font-size:11px; color:#8faac4; margin-top:3px; }

  /* ── cards layout ── */
  .card {
    background:var(--card); border-radius:var(--radius);
    box-shadow:var(--shadow); overflow:hidden;
    animation: fadeUp 0.45s ease both; animation-delay:.28s;
  }
  .card-header {
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 20px 14px; border-bottom:1px solid var(--border);
    flex-wrap:wrap; gap:8px;
  }
  .card-title { font-size:15px; font-weight:700; color:var(--primary); }
  .card-sub   { font-size:12px; color:var(--muted); }
  .card-body  { padding:20px; }

  /* ── grid layouts ── */
  .grid-3 {
    display:grid; grid-template-columns:repeat(3,1fr);
    gap:20px; margin-bottom:24px;
  }
  .grid-2 {
    display:grid; grid-template-columns:1fr 1.4fr;
    gap:20px; margin-bottom:24px;
  }
  @media (max-width:1100px) { .grid-3 { grid-template-columns:1fr 1fr; } }
  @media (max-width:900px)  { .grid-3, .grid-2 { grid-template-columns:1fr; } }

  /* ── pie chart wrapper ── */
  .pie-wrap { position:relative; height:220px; display:flex; justify-content:center; }
  .pie-center {
    position:absolute; top:50%; left:50%; transform:translate(-50%,-50%);
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    pointer-events:none; text-align:center;
  }
  .pie-center-val { font-size:26px; font-weight:900; color:var(--primary); line-height:1; }
  .pie-center-lbl { font-size:10px; color:var(--muted); text-transform:uppercase; letter-spacing:.8px; margin-top:3px; }

  .pie-legend { display:flex; flex-direction:column; gap:7px; margin-top:16px; }
  .leg-item {
    display:flex; align-items:center; gap:8px;
    font-size:12px; color:var(--muted);
  }
  .leg-dot  { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
  .leg-name { flex:1; color:#2e4a6a; font-weight:500; }
  .leg-pct  { font-size:11px; font-weight:700; color:var(--primary); min-width:34px; text-align:right; }

  /* ── monthly bar chart ── */
  .bar-wrap { position:relative; height:260px; }

  /* ── team table ── */
  .table-wrap { overflow-x:auto; }
  table { width:100%; border-collapse:collapse; min-width:340px; }
  thead th {
    text-align:left; padding:10px 14px;
    background:#eef4fb; color:#2a4a70;
    font-size:11px; font-weight:700;
    border-bottom:2px solid #ccdaec;
    letter-spacing:.5px; text-transform:uppercase; white-space:nowrap;
  }
  thead th.num { text-align:center; }
  tbody tr { border-bottom:1px solid #edf2f7; transition:background .18s; }
  tbody tr:last-child { border-bottom:none; }
  tbody tr:hover { background:#f3f8fd; }
  tbody td { padding:12px 14px; font-size:13px; color:#2e4a6a; vertical-align:middle; }
  tbody td.num { text-align:center; font-weight:700; }

  .badge {
    display:inline-flex; align-items:center; gap:4px;
    padding:3px 10px; border-radius:999px;
    font-size:11px; font-weight:600; white-space:nowrap;
  }
  .badge::before { content:""; width:5px; height:5px; border-radius:50%; background:currentColor; }
  .b-blue   { background:rgba(74,144,226,0.13); color:#1d5fa8; }
  .b-green  { background:rgba(53,179,126,0.13); color:#1a7a54; }
  .b-orange { background:rgba(244,166,42,0.14);  color:#9a6000; }

  /* ── summary row in team table ── */
  .team-total-row td { background:#f5f9ff; font-weight:700; font-size:13px; border-top:2px solid #ccdaec; }

  @keyframes fadeUp {
    from { opacity:0; transform:translateY(16px); }
    to   { opacity:1; transform:translateY(0); }
  }
</style>

<section class="content">

  <!-- ===== Year Hero Banner ===== -->
  <div class="year-hero">
    <div class="year-hero-left">
      <div class="year-hero-eyebrow">Annual Report</div>
      <div class="year-hero-title">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Annual Summary Report <%= year %>
      </div>
      <div class="year-hero-sub">Project overview, PO values and team performance for <%= year %></div>
    </div>
    <div class="year-hero-right">
      <div class="year-selector-wrap">
        <label for="yearSelect">Select Year</label>
        <select id="yearSelect" class="year-select" onchange="location.href='/summary-year?year='+this.value">
          <% availableYears.forEach(function(y) { %>
            <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
          <% }); %>
        </select>
      </div>
    </div>
  </div>

  <!-- ===== 6 Stat Cards ===== -->
  <div class="stats-grid">

    <div class="stat-card">
      <div class="stat-icon si-blue">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Total Projects</div>
        <div class="stat-value"><%= summary.total_projects %></div>
        <div class="stat-sub">Year <%= year %></div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-green">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Completed</div>
        <div class="stat-value"><%= summary.completed %></div>
        <div class="stat-sub">Projects closed</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-orange">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Incomplete</div>
        <div class="stat-value"><%= summary.not_completed %></div>
        <div class="stat-sub">In Progress + Delayed</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-purple">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Total PO Value</div>
        <div class="stat-value">฿<%= (Number(summary.total_po_value)/1000000).toFixed(2) %>M</div>
        <div class="stat-sub"><%= Number(summary.total_po_value).toLocaleString('en-US',{minimumFractionDigits:0}) %> THB</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-teal">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Completed PO</div>
        <div class="stat-value">฿<%= (Number(summary.completed_po_value)/1000000).toFixed(2) %>M</div>
        <div class="stat-sub"><%= Number(summary.completed_po_value).toLocaleString('en-US',{minimumFractionDigits:0}) %> THB</div>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon si-red">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/>
        </svg>
      </div>
      <div class="stat-body">
        <div class="stat-label">Pending PO</div>
        <div class="stat-value">฿<%= (Number(summary.remaining_po_value)/1000000).toFixed(2) %>M</div>
        <div class="stat-sub"><%= Number(summary.remaining_po_value).toLocaleString('en-US',{minimumFractionDigits:0}) %> THB</div>
      </div>
    </div>

  </div>

  <!-- ===== Row 2: 3 Pie Charts ===== -->
  <div class="grid-3" style="margin-bottom:24px;">

    <!-- Pie 1: Project Types / Systems -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">System / Project Type</span>
        <span class="card-sub"><%= typeStats.length %> types</span>
      </div>
      <div class="card-body">
        <div class="pie-wrap">
          <canvas id="typeChart"></canvas>
          <div class="pie-center"><div class="pie-center-val" id="typeTotalVal">—</div><div class="pie-center-lbl">Total</div></div>
        </div>
        <div class="pie-legend" id="typeLegend"></div>
      </div>
    </div>

    <!-- Pie 2: Value Range -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Project Value Range</span>
        <span class="card-sub">Grouped by PO value</span>
      </div>
      <div class="card-body">
        <div class="pie-wrap">
          <canvas id="valueChart"></canvas>
          <div class="pie-center"><div class="pie-center-val" id="valueTotalVal">—</div><div class="pie-center-lbl">Total</div></div>
        </div>
        <div class="pie-legend" id="valueLegend"></div>
      </div>
    </div>

    <!-- Pie 3: Region / Province -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Region / Province</span>
        <span class="card-sub"><%= regionStats.length %> areas</span>
      </div>
      <div class="card-body">
        <div class="pie-wrap">
          <canvas id="regionChart"></canvas>
          <div class="pie-center"><div class="pie-center-val" id="regionTotalVal">—</div><div class="pie-center-lbl">Total</div></div>
        </div>
        <div class="pie-legend" id="regionLegend"></div>
      </div>
    </div>

  </div>

  <!-- ===== Row 3: Monthly Bar Chart ===== -->
  <div class="card" style="margin-bottom:24px; animation-delay:.34s;">
    <div class="card-header">
      <span class="card-title">Monthly Projects — Year <%= year %></span>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <span class="leg-item"><span class="leg-dot" style="background:#6366F1;"></span>Total</span>
        <span class="leg-item"><span class="leg-dot" style="background:#4A90E2;"></span>In Progress</span>
        <span class="leg-item"><span class="leg-dot" style="background:#35B37E;"></span>Completed</span>
        <span class="leg-item"><span class="leg-dot" style="background:#E45757;"></span>Delayed</span>
      </div>
    </div>
    <div class="card-body">
      <div class="bar-wrap"><canvas id="monthlyChart"></canvas></div>
    </div>
  </div>

  <!-- ===== Row 4: Team Summary Table ===== -->
  <div class="card" style="animation-delay:.40s;">
    <div class="card-header">
      <span class="card-title">Team Performance Summary</span>
      <span class="card-sub">Year <%= year %></span>
    </div>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Team</th>
            <th class="num" style="color:#6366F1;">Total Projects</th>
            <th class="num" style="color:#35B37E;">Completed</th>
            <th class="num" style="color:#E45757;">Incomplete</th>
            <th class="num">% Done</th>
          </tr>
        </thead>
        <tbody>
          <% teamSummary.forEach(function(t) {
            const pct = t.total > 0 ? Math.round((t.completed / t.total)*100) : 0;
          %>
          <tr>
            <td><strong><%= t.team_name %></strong></td>
            <td class="num" style="color:#1d5fa8;"><%= t.total %></td>
            <td class="num" style="color:#1a7a54;"><%= t.completed %></td>
            <td class="num" style="color:#c0392b;"><%= t.not_completed %></td>
            <td class="num">
              <div style="display:flex;align-items:center;gap:8px;justify-content:center;">
                <div style="width:80px;height:6px;background:#e6edf6;border-radius:999px;overflow:hidden;">
                  <div style="height:100%;width:<%= pct %>%;background:<%= pct>=80?'#35B37E':pct>=50?'#F4A62A':'#E45757' %>;border-radius:999px;transition:width 1s ease .3s;"></div>
                </div>
                <span style="font-size:12px;font-weight:700;color:var(--primary);min-width:30px;"><%= pct %>%</span>
              </div>
            </td>
          </tr>
          <% }); %>

          <% if (teamSummary.length === 0) { %>
          <tr><td colspan="5" style="text-align:center;color:var(--muted);padding:24px;">No data available</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

</section>

<script>
  /* ── colour palettes ── */
  const PIE_COLORS = [
    '#4A90E2','#35B37E','#F4A62A','#9B59B6','#E45757','#14B8A6',
    '#F59E0B','#EC4899','#6366F1','#10B981','#EF4444','#8B5CF6',
    '#06B6D4','#84CC16','#F97316',
  ];

  function buildLegend(containerId, labels, data, colors) {
    const el = document.getElementById(containerId);
    if (!el) return;
    const total = data.reduce((a, b) => a + b, 0);
    el.innerHTML = labels.map((l, i) => {
      const pct = total > 0 ? Math.round((data[i] / total) * 100) : 0;
      return `<div class="leg-item">
        <div class="leg-dot" style="background:${colors[i % colors.length]};"></div>
        <span class="leg-name">${l}</span>
        <span class="leg-pct">${pct}%</span>
      </div>`;
    }).join('');
  }

  function makePie(canvasId, totalElId, labels, data, colors) {
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;
    const total = data.reduce((a, b) => a + b, 0);
    const totalEl = document.getElementById(totalElId);
    if (totalEl) totalEl.textContent = total;
    new Chart(ctx, {
      type: 'doughnut',
      data: {
        labels,
        datasets: [{
          data,
          backgroundColor: colors.slice(0, labels.length).map(c => c + 'cc'),
          borderColor:      colors.slice(0, labels.length),
          borderWidth: 2,
          hoverOffset: 10,
        }]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        cutout: '62%',
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1E3A5F', titleColor: '#fff', bodyColor: 'rgba(255,255,255,0.8)',
            padding: 10, cornerRadius: 8,
            callbacks: {
              label: ctx => {
                const pct = total > 0 ? Math.round((ctx.parsed / total) * 100) : 0;
                return ` ${ctx.label}: ${ctx.parsed} (${pct}%)`;
              }
            }
          }
        }
      }
    });
  }

  /* ── Pie 1: Type / Systems ── */
  const _typeStats   = <%- JSON.stringify(typeStats) %>;
  const typeLabels   = _typeStats.length ? _typeStats.map(t => t.name) : ['No data'];
  const typeData     = _typeStats.length ? _typeStats.map(t => t.count) : [1];
  const typeColors   = _typeStats.length ? PIE_COLORS : ['#d1d5db'];
  makePie('typeChart', 'typeTotalVal', typeLabels, typeData, typeColors);
  buildLegend('typeLegend', typeLabels, typeData, typeColors);

  /* ── Pie 2: Region ── */
  const _regionStats  = <%- JSON.stringify(regionStats) %>;
  const regionLabels  = _regionStats.length ? _regionStats.map(r => r.region) : ['No data'];
  const regionData    = _regionStats.length ? _regionStats.map(r => r.count)  : [1];
  const regionColors  = _regionStats.length ? PIE_COLORS.slice(3) : ['#d1d5db'];
  makePie('regionChart', 'regionTotalVal', regionLabels, regionData, regionColors);
  buildLegend('regionLegend', regionLabels, regionData, regionColors);

  /* ── Pie 3: Value Range ── */
  const _valueStats  = <%- JSON.stringify(valueRangeStats) %>;
  const valueLabels  = _valueStats.map(v => v.range);
  const valueData    = _valueStats.map(v => v.count);
  const valueColors  = ['#4A90E2','#35B37E','#F4A62A','#9B59B6','#E45757'];
  makePie('valueChart', 'valueTotalVal', valueLabels, valueData, valueColors);
  buildLegend('valueLegend', valueLabels, valueData, valueColors);

  /* ── Monthly Bar Chart ── */
  const _monthly = <%- JSON.stringify(monthlySummary) %>;
  const monthCtx = document.getElementById('monthlyChart').getContext('2d');
  new Chart(monthCtx, {
    type: 'bar',
    data: {
      labels: _monthly.map(m => m.month),
      datasets: [
        { label:'รวม',        data: _monthly.map(m => m.total),       backgroundColor:'rgba(99,102,241,0.20)',  borderColor:'#6366F1', borderWidth:1.5, borderRadius:4 },
        { label:'In Progress',data: _monthly.map(m => m.in_progress), backgroundColor:'rgba(74,144,226,0.20)',  borderColor:'#4A90E2', borderWidth:1.5, borderRadius:4 },
        { label:'Completed',  data: _monthly.map(m => m.completed),   backgroundColor:'rgba(53,179,126,0.20)',  borderColor:'#35B37E', borderWidth:1.5, borderRadius:4 },
        { label:'Delayed',    data: _monthly.map(m => m.delayed),     backgroundColor:'rgba(228,87,87,0.18)',   borderColor:'#E45757', borderWidth:1.5, borderRadius:4 },
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode:'index', intersect:false },
      plugins: {
        legend: { display:false },
        tooltip: {
          backgroundColor:'#1E3A5F', titleColor:'#fff', bodyColor:'rgba(255,255,255,0.8)',
          padding:12, cornerRadius:10, boxPadding:5,
          callbacks: { label: ctx => ` ${ctx.dataset.label}: ${ctx.parsed.y} projects` }
        }
      },
      scales: {
        x: { grid:{ color:'rgba(217,226,236,0.5)' }, ticks:{ color:'#56718f', font:{size:12} } },
        y: { beginAtZero:true, grid:{ color:'rgba(217,226,236,0.5)' }, ticks:{ color:'#56718f', font:{size:11}, stepSize:1, callback: v => v+' projects' } }
      }
    }
  });
</script>
