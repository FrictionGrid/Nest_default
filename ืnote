1 npm i -g @nestjs/cli = ติดตั้ง Nest CLI
2 nest new "name project" = สร้างโปรเจคใหม่
3 npm run start:dev = คำสั่งรัน server
4 npm install @nestjs/config 
5 สร้างไฟล์ .env เเละ .env.example นอกสุด
6 ไฟล์ public สร้างได้เลย
7 สร้าง docker-compose.yml นอกสุด
8 npm install ejs = ติดตั้ง EJS
9 จัดการไฟล์ main.ts กับ AppModule
10 nest g resource "name" = คำสั่งสร้างไฟล์